{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"strictNullChecks": true,
		"types": ["vitest/globals", "@testing-library/jest-dom", "vitest-axe/extend-expect"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*", "src/test/**/*", "vitest.config.ts", "vitest.astro.config.ts", "unlighthouse.config.ts", "playwright.config.ts", "tests/**/*"]
}
