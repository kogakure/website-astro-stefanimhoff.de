---
import DesignSystemLayout from '@/layouts/DesignSystemLayout.astro';
import 'lite-youtube-embed/src/lite-yt-embed.css';

// UI components
import Text from '@/components/ui/Text';
import Headline from '@/components/ui/Headline';
import Subheadline from '@/components/ui/Subheadline';
import Subsubheadline from '@/components/ui/Subsubheadline';
import Title from '@/components/ui/Title';
import SectionLabel from '@/components/ui/SectionLabel';
import TextLink from '@/components/ui/TextLink';
import MoreLink from '@/components/ui/MoreLink';
import Divider from '@/components/ui/Divider';
import Tag from '@/components/ui/Tag';
import { UnorderedList } from '@/components/ui/UnorderedList';
import { OrderedList } from '@/components/ui/OrderedList';
import { ListItem } from '@/components/ui/ListItem';
import Strong from '@/components/ui/Strong';
import Em from '@/components/ui/Em';

// Content components
import Banner from '@/components/content/Banner';
import Blockquote from '@/components/content/Blockquote';
import Pullquote from '@/components/content/Pullquote';
import InlineCode from '@/components/content/InlineCode';
import ColorSwatch from '@/components/content/ColorSwatch';
import ColorSwatchPrimary from '@/components/content/ColorSwatchPrimary';
import ColorSwatchMini from '@/components/content/ColorSwatchMini';
import ColorStack from '@/components/content/ColorStack';

// Additional UI components
import { Strikethrough } from '@/components/ui/Strikethrough';
import { Inserted } from '@/components/ui/Inserted';
import { Marked } from '@/components/ui/Marked';
import { Subscript } from '@/components/ui/Subscript';
import { Superscript } from '@/components/ui/Superscript';
import { Table } from '@/components/ui/Table';
import { TableHead } from '@/components/ui/TableHead';
import { TableBody } from '@/components/ui/TableBody';
import { TableRow } from '@/components/ui/TableRow';
import { TableHeaderCell } from '@/components/ui/TableHeaderCell';
import { TableCell } from '@/components/ui/TableCell';
import { CodeBlock } from '@/components/ui/CodeBlock';
import { FootnoteSection } from '@/components/ui/FootnoteSection';
import { TaskCheckbox } from '@/components/ui/TaskCheckbox';
import { Badge } from '@/components/ui/Badge';
import { Link } from '@/components/ui/Link';
import { EssayLink } from '@/components/ui/EssayLink';
import { Flag } from '@/components/ui/Flag';
import { HaikuItem } from '@/components/ui/HaikuItem';
import { JapanesePoem } from '@/components/ui/JapanesePoem';
import { QuoteAttribution } from '@/components/ui/QuoteAttribution';
import { Switch } from '@/components/ui/switch';
// Tooltip omitted from SSR demo — TooltipContent uses ReactDOM.createPortal (portal-based, breaks SSR)

// Additional content components
import { AudioCard } from '@/components/content/AudioCard';
import { BookCard } from '@/components/content/BookCard';
import { VideoCard } from '@/components/content/VideoCard';
import { MediaLinkRow } from '@/components/content/MediaLinkRow';
import { AppleTVFlag } from '@/components/content/AppleTVFlag';
import { NetflixFlag } from '@/components/content/NetflixFlag';
import { PrimeVideoFlag } from '@/components/content/PrimeVideoFlag';
import { Platform } from '@/components/content/Platform';
import { AmazonBook } from '@/components/content/AmazonBook';
import { Book } from '@/components/content/Book';
import { Bookshelf } from '@/components/content/Bookshelf';
import { YouTube } from '@/components/content/YouTube';
import { Spotify } from '@/components/content/Spotify';
import { Figure } from '@/components/content/Figure';
import ContentImage from '@/components/content/Image';
import { MarkdownImage } from '@/components/content/MarkdownImage';
import { DownloadLink } from '@/components/content/DownloadLink';
import { EmailLink } from '@/components/content/EmailLink';
import { ProductLink } from '@/components/content/ProductLink';
import { Ruby } from '@/components/content/Ruby';
import { Verse } from '@/components/content/Verse';
// RSSText renders null — no demo component needed

// Interactive components
// BarChart / DoughnutChart: Recharts ResponsiveContainer needs DOM — use client:visible in MDX
// HoverPreview: no visible SSR output — activated via data-hover-preview anchors
import { LightboxRoot } from '@/components/interactive/LightboxRoot';
import { TableOfContents } from '@/components/interactive/TableOfContents';
import { Marquee } from '@/components/interactive/Marquee';
import { Roadmap } from '@/components/interactive/Roadmap';
import { SeriesStepper } from '@/components/interactive/SeriesStepper';

// Showcase wrapper
import ComponentShowcase from '@/components/design-system/ComponentShowcase';

const sampleImg = `data:image/svg+xml,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="800" height="450"><rect width="800" height="450" fill="#900B20"/><text x="400" y="225" text-anchor="middle" dominant-baseline="middle" fill="#E6E6E6" font-family="sans-serif" font-size="18">Sample image</text></svg>')}`;
const sampleBookImg = `data:image/svg+xml,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="200" height="300"><rect width="200" height="300" fill="#900B20"/><text x="100" y="150" text-anchor="middle" dominant-baseline="middle" fill="#E6E6E6" font-family="sans-serif" font-size="12">Book cover</text></svg>')}`;
---

<DesignSystemLayout
	title="Components"
	description="Every UI, content, and interactive component in the Ma system."
	kanji="部"
	order={11}
	currentSlug="components"
	prev={{ title: 'Accessibility', slug: 'accessibility' }}
>
	<p class="text-hai mbe-10 font-mono text-xs uppercase tracking-wider">UI Primitives</p>

	<ComponentShowcase
		name="Text"
		importPath="components/ui/Text"
		category="ui"
		description="Body copy paragraph. Default element: <p>. Accepts as prop for semantic override."
		props={[
			{ name: 'as', type: 'ElementType', default: '"p"', description: 'Rendered element' },
			{ name: 'className', type: 'string', description: 'Tailwind class override' },
			{ name: 'children', type: 'ReactNode', description: 'Content' },
		]}
	>
		<Text
			>The space between. Nearly two decades at the intersection of design and code have led
			to a single conviction: the discipline of leaving things out is the discipline that
			matters most.</Text
		>
	</ComponentShowcase>

	<ComponentShowcase
		name="Title"
		importPath="components/ui/Title"
		category="ui"
		description="H1 for page content (not the page hero). Boska display."
	>
		<Title>The space between</Title>
	</ComponentShowcase>

	<ComponentShowcase
		name="Headline"
		importPath="components/ui/Headline"
		category="ui"
		description="H2 section heading. Switzer, text-5."
		props={[
			{ name: 'as', type: 'ElementType', default: '"h2"', description: 'Rendered element' },
		]}
	>
		<Headline>Section heading</Headline>
	</ComponentShowcase>

	<ComponentShowcase
		name="Subheadline"
		importPath="components/ui/Subheadline"
		category="ui"
		description="H3 heading. Switzer, text-4."
	>
		<Subheadline>Sub-section heading</Subheadline>
	</ComponentShowcase>

	<ComponentShowcase
		name="Subsubheadline"
		importPath="components/ui/Subsubheadline"
		category="ui"
		description="H4 heading. Switzer, text-3 bold."
	>
		<Subsubheadline>Minor heading</Subsubheadline>
	</ComponentShowcase>

	<ComponentShowcase
		name="SectionLabel"
		importPath="components/ui/SectionLabel"
		category="ui"
		description="Uppercase mono label for section titles and metadata."
	>
		<SectionLabel>Design tokens</SectionLabel>
	</ComponentShowcase>

	<ComponentShowcase
		name="TextLink"
		importPath="components/ui/TextLink"
		category="ui"
		description="Inline hyperlink. Beni, underline-on-hover slide animation."
	>
		<Text
			>Read more about <TextLink href="#">Ma design principles</TextLink> and how they inform every
			decision in the system.</Text
		>
	</ComponentShowcase>

	<ComponentShowcase
		name="MoreLink"
		importPath="components/ui/MoreLink"
		category="ui"
		description="Navigation arrow link with animated arrow translation."
		props={[
			{ name: 'href', type: 'string', description: 'Link destination' },
			{ name: 'text', type: 'string', description: 'Link label' },
		]}
	>
		<MoreLink href="#" text="View all essays" />
	</ComponentShowcase>

	<ComponentShowcase
		name="Divider"
		importPath="components/ui/Divider"
		category="ui"
		description="Horizontal rule. Usuzumi, 1px."
	>
		<Divider />
	</ComponentShowcase>

	<ComponentShowcase
		name="Tag"
		importPath="components/ui/Tag"
		category="ui"
		description="Filter tag / label pill. Supports active state, href for nav, or onClick for filter."
		props={[
			{
				name: 'active',
				type: 'boolean',
				default: 'false',
				description: 'Active/selected state',
			},
			{ name: 'href', type: 'string', description: 'Renders as <a> when provided' },
			{
				name: 'onClick',
				type: '() => void',
				description: 'Renders as <button> when provided',
			},
		]}
	>
		<div class="flex flex-wrap gap-2">
			<Tag href="#">Design</Tag>
			<Tag href="#" active>Typography</Tag>
			<Tag href="#">Motion</Tag>
			<Tag href="#">Color</Tag>
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="UnorderedList / OrderedList / ListItem"
		importPath="components/ui/UnorderedList"
		category="ui"
		description="Styled list primitives. Always use ListItem as children."
	>
		<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
			<UnorderedList>
				<ListItem>Exclude the non-essential</ListItem>
				<ListItem>Favour decisions that age well</ListItem>
				<ListItem>The discipline of leaving things out</ListItem>
			</UnorderedList>
			<OrderedList>
				<ListItem>Establish the grid</ListItem>
				<ListItem>Set the type</ListItem>
				<ListItem>Add colour sparingly</ListItem>
			</OrderedList>
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="Strong / Em"
		importPath="components/ui/Strong"
		category="ui"
		description="Inline text emphasis. Strong: Switzer Bold. Em: Switzer Italic."
	>
		<Text
			>The system is built on <Strong>contrast as a principle</Strong>, not as an accident.
			Display type is set in <Em>Boska Bold</Em> at extreme sizes.</Text
		>
	</ComponentShowcase>

	<ComponentShowcase
		name="Strikethrough / Inserted / Marked"
		importPath="components/ui/Strikethrough"
		category="ui"
		description="Semantic inline marks. Strikethrough: deleted text (del). Inserted: added text (ins). Marked: highlighted text (mark)."
	>
		<Text
			><Strikethrough>deleted content</Strikethrough>{' '}was replaced by{' '}
			<Inserted>inserted content</Inserted>{' '}and some text is{' '}
			<Marked>highlighted for emphasis</Marked>.</Text
		>
	</ComponentShowcase>

	<ComponentShowcase
		name="Subscript / Superscript"
		importPath="components/ui/Subscript"
		category="ui"
		description="Inline typographic positioning. Subscript renders sub. Superscript renders sup."
	>
		<Text
			>Water is H<Subscript>2</Subscript>O. A footnote reference<Superscript>1</Superscript> links
			to the note.</Text
		>
	</ComponentShowcase>

	<ComponentShowcase
		name="Table"
		importPath="components/ui/Table"
		category="ui"
		description="Full table family: Table, TableHead, TableBody, TableRow, TableHeaderCell, TableCell. Responsive with overflow-x-auto."
	>
		<Table>
			<TableHead>
				<TableRow>
					<TableHeaderCell>Component</TableHeaderCell>
					<TableHeaderCell>Element</TableHeaderCell>
					<TableHeaderCell>Purpose</TableHeaderCell>
				</TableRow>
			</TableHead>
			<TableBody>
				<TableRow>
					<TableCell>Text</TableCell>
					<TableCell>p</TableCell>
					<TableCell>Body copy paragraph</TableCell>
				</TableRow>
				<TableRow>
					<TableCell>Headline</TableCell>
					<TableCell>h2</TableCell>
					<TableCell>Section heading</TableCell>
				</TableRow>
				<TableRow>
					<TableCell>Tag</TableCell>
					<TableCell>a / button / span</TableCell>
					<TableCell>Filter label pill</TableCell>
				</TableRow>
			</TableBody>
		</Table>
	</ComponentShowcase>

	<ComponentShowcase
		name="CodeBlock"
		importPath="components/ui/CodeBlock"
		category="ui"
		description="Styled pre element for code blocks. Fira Code, Kiri background, overflow-x-auto."
	>
		<CodeBlock
			>{
				`const greeting = (name: string) => \`Hello, \${name}!\`;\ngreeting('Ma Design System');`
			}</CodeBlock
		>
	</ComponentShowcase>

	<ComponentShowcase
		name="FootnoteSection"
		importPath="components/ui/FootnoteSection"
		category="ui"
		description="Semantic container for footnotes at the end of essay content. Renders section.footnotes with muted text-2 sizing."
	>
		<FootnoteSection>
			<Text className="text-2 text-hai mbe-0"
				>1. Boska Variable, Barbara Bigosińska, Fontshare/ITF, 2022.</Text
			>
		</FootnoteSection>
	</ComponentShowcase>

	<ComponentShowcase
		name="TaskCheckbox"
		importPath="components/ui/TaskCheckbox"
		category="ui"
		description="Disabled styled checkbox for GFM task list items (- [ ] / - [x] syntax in MDX)."
	>
		<div class="flex flex-col gap-2">
			<label class="flex items-center gap-2">
				<TaskCheckbox />
				<Text className="mbe-0">Unchecked task item</Text>
			</label>
			<label class="flex items-center gap-2">
				<TaskCheckbox defaultChecked />
				<Text className="mbe-0">Checked task item</Text>
			</label>
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="Badge"
		importPath="components/ui/Badge"
		category="ui"
		description="Small status/label chip. Variants: default, favorite (Beni), paid, language."
		props={[
			{
				name: 'variant',
				type: '"default" | "favorite" | "paid" | "language"',
				default: '"default"',
				description: 'Visual variant',
			},
		]}
	>
		<div class="flex flex-wrap gap-2">
			<Badge>Default</Badge>
			<Badge variant="favorite">Favorite</Badge>
			<Badge variant="paid">Paid</Badge>
			<Badge variant="language">DE</Badge>
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="Link"
		importPath="components/ui/Link"
		category="ui"
		description="Base anchor element. Auto-detects external URLs — adds rel noopener and target _blank."
		props={[{ name: 'href', type: 'string', default: '"#"', description: 'Link destination' }]}
	>
		<div class="flex gap-6">
			<Link href="#">Internal link</Link>
			<Link href="https://stefanimhoff.de">External link ↗</Link>
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="EssayLink"
		importPath="components/ui/EssayLink"
		category="ui"
		description="Unstyled link that reveals Beni colour on hover. Used in essay list cards as a wrapper link."
	>
		<EssayLink href="#">The discipline of leaving things out — an essay on minimalism</EssayLink
		>
	</ComponentShowcase>

	<ComponentShowcase
		name="Flag"
		importPath="components/ui/Flag"
		category="ui"
		description="Inline monospace label tag. Renders as Link when href provided, otherwise span."
		props={[
			{ name: 'label', type: 'string', description: 'Text displayed inside the flag' },
			{ name: 'href', type: 'string', description: 'Renders as Link when provided' },
		]}
	>
		<Text>
			A generic flag <Flag label="NEW" /> used inline. Also linkable: <Flag
				href="#"
				label="tv"
			/>.
		</Text>
	</ComponentShowcase>

	<ComponentShowcase
		name="HaikuItem"
		importPath="components/ui/HaikuItem"
		category="ui"
		description="Renders a single haiku with German original and English translation. Newlines become ` / ` separators."
		props={[
			{
				name: 'de',
				type: 'string',
				description: 'German haiku text (newline-separated lines)',
			},
			{ name: 'en', type: 'string', description: 'English translation' },
		]}
	>
		<ul class="list-none">
			<HaikuItem
				de={`Im Herbstwind weht\nein gelbes Blatt vom Baum —\nStille danach.`}
				en="In the autumn wind / a yellow leaf falls from the tree — / silence after."
			/>
		</ul>
	</ComponentShowcase>

	<ComponentShowcase
		name="JapanesePoem"
		importPath="components/ui/JapanesePoem"
		category="ui"
		description="Large display Japanese text strip. Used inside Marquee for full-bleed poem (Datsuzoku). Renders default poem when no children."
		props={[
			{ name: 'as', type: 'ElementType', default: '"span"', description: 'Rendered element' },
		]}
	>
		<div class="overflow-hidden">
			<JapanesePoem />
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="QuoteAttribution"
		importPath="components/ui/QuoteAttribution"
		category="ui"
		description="Attribution footer for Blockquote. — Author, Source (optional link). Renders null when neither author nor source provided."
		props={[
			{ name: 'author', type: 'string', description: 'Author name' },
			{ name: 'source', type: 'string', description: 'Work title' },
			{ name: 'sourceUrl', type: 'string', description: 'Optional link for source' },
		]}
	>
		<QuoteAttribution author="Ludwig Wittgenstein" source="Tractatus Logico-Philosophicus" />
	</ComponentShowcase>

	<ComponentShowcase
		name="Switch"
		importPath="components/ui/switch"
		category="ui"
		description="shadcn/ui Switch toggle. Two sizes: default and sm."
		props={[
			{
				name: 'size',
				type: '"default" | "sm"',
				default: '"default"',
				description: 'Toggle size',
			},
		]}
	>
		<div class="flex items-center gap-6">
			<Switch />
			<Switch defaultChecked />
			<Switch size="sm" />
			<Switch size="sm" defaultChecked />
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="Tooltip"
		importPath="components/ui/tooltip"
		category="ui"
		description="shadcn/ui Tooltip. Wrap trigger in TooltipTrigger, content in TooltipContent. Requires TooltipProvider at root. Use client:load — TooltipContent uses a portal and requires the DOM."
	>
		<p class="text-hai font-mono text-xs">
			Requires <code class="text-beni">client:load</code> — portal-based, SSR-safe demo not possible.
			Pattern: <code class="text-sumi dark:text-washi"
				>TooltipProvider &gt; Tooltip &gt; TooltipTrigger + TooltipContent</code
			>
		</p>
	</ComponentShowcase>

	<p class="text-hai mbe-10 mbs-16 font-mono text-xs uppercase tracking-wider">
		Content Components
	</p>

	<ComponentShowcase
		name="Banner"
		importPath="components/content/Banner"
		category="content"
		description="Aside callout. Default and accent (left Beni border) tones. Optional collapsible disclosure."
		props={[
			{
				name: 'tone',
				type: '"default" | "accent"',
				default: '"default"',
				description: 'Visual emphasis',
			},
			{
				name: 'summary',
				type: 'string',
				description: 'Renders as <details> with this summary label',
			},
			{ name: 'open', type: 'boolean', description: 'Initial open state for disclosure' },
		]}
	>
		<div class="flex flex-col gap-4">
			<Banner>
				<Text
					>Default banner — informational callout with neutral styling on Kiri background.</Text
				>
			</Banner>
			<Banner tone="accent">
				<Text
					>Accent banner — left Beni border draws attention. Use for important notes.</Text
				>
			</Banner>
			<Banner summary="Collapsible banner">
				<Text
					>This content is hidden behind a disclosure. The summary label acts as the
					trigger.</Text
				>
			</Banner>
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="Blockquote"
		importPath="components/content/Blockquote"
		category="content"
		description="Styled blockquote with optional attribution."
	>
		<Blockquote>
			<Text>The discipline of leaving things out is the discipline that matters most.</Text>
		</Blockquote>
	</ComponentShowcase>

	<ComponentShowcase
		name="Pullquote"
		importPath="components/content/Pullquote"
		category="content"
		description="Large display quote for editorial emphasis. Boska, full-bleed within column."
	>
		<Pullquote text="The space between is not empty — it is ma." />
	</ComponentShowcase>

	<ComponentShowcase
		name="InlineCode"
		importPath="components/content/InlineCode"
		category="content"
		description="Inline code span. Fira Code, Kiri background, radius-1."
	>
		<Text
			>Use <InlineCode>var(--color-beni)</InlineCode> for accent elements. Never use <InlineCode
				>--color-sumi</InlineCode
			> on near-black backgrounds.</Text
		>
	</ComponentShowcase>

	<p class="text-hai mbe-10 mbs-16 font-mono text-xs uppercase tracking-wider">
		Color Components
	</p>

	<ComponentShowcase
		name="ColorSwatchPrimary"
		importPath="components/content/ColorSwatchPrimary"
		category="content"
		description="Large color swatch card with hex, name, kanji, and usage description."
		props={[
			{ name: 'color', type: 'string', description: 'Hex color value' },
			{ name: 'name', type: 'string', description: 'Color name' },
			{ name: 'kanji', type: 'string', description: 'Japanese character' },
			{ name: 'description', type: 'string', description: 'Usage description' },
		]}
	>
		<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
			<ColorSwatchPrimary
				color="#900B20"
				name="Beni"
				kanji="紅"
				description="Accent, links, focus ring"
			/>
			<ColorSwatchPrimary
				color="#0E0D0C"
				name="Sumi"
				kanji="墨"
				description="Primary text, headings"
			/>
			<ColorSwatchPrimary
				color="#E6E6E6"
				name="Washi"
				kanji="和紙"
				description="Primary background"
			/>
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="ColorSwatch"
		importPath="components/content/ColorSwatch"
		category="content"
		description="Standard color swatch with name, hex, optional kanji and description."
		props={[
			{ name: 'color', type: 'string', description: 'Hex color value' },
			{ name: 'name', type: 'string', description: 'Color name' },
			{ name: 'kanji', type: 'string', description: 'Japanese character (optional)' },
			{ name: 'description', type: 'string', description: 'Usage note (optional)' },
		]}
	>
		<div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
			<ColorSwatch color="#F2F2F0" name="Kiri" description="Card backgrounds" />
			<ColorSwatch color="#C8C8C4" name="Usuzumi" description="Borders, dividers" />
			<ColorSwatch color="#A0A09C" name="Hai" description="Muted text, captions" />
			<ColorSwatch color="#6B6B67" name="Nezumi" description="Mid-tone borders" />
		</div>
	</ComponentShowcase>

	<ComponentShowcase
		name="ColorSwatchMini"
		importPath="components/content/ColorSwatchMini"
		category="content"
		description="Inline 16×16 color chip. Used within text or dense tables."
		props={[{ name: 'color', type: 'string', description: 'Hex color value' }]}
	>
		<p class="flex flex-wrap items-center gap-3 font-mono text-sm text-sumi dark:text-washi">
			<span class="flex items-center gap-1.5"><ColorSwatchMini color="#900B20" /> Beni</span>
			<span class="flex items-center gap-1.5"
				><ColorSwatchMini color="#B83A4E" /> Beni Light</span
			>
			<span class="flex items-center gap-1.5"
				><ColorSwatchMini color="#C75566" /> Beni Muted</span
			>
			<span class="flex items-center gap-1.5"
				><ColorSwatchMini color="#F2D5DA" /> Beni Pale</span
			>
			<span class="flex items-center gap-1.5"
