---
import type { CollectionEntry } from 'astro:content';
type Journal = CollectionEntry<'journal'>;
import { getCollection } from 'astro:content';

import { formatPosts } from '../utils';

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeading from '../components/ui/PageHeading';
import PageSection from '../components/ui/PageSection';
import TextLink from '../components/ui/TextLink';
import WritingPage from '../components/interactive/WritingPage';

const allPosts = await getCollection('journal', ({ data }: Journal) => !data.draft);
const formattedPosts = formatPosts(allPosts, {});

const uniqueTags = [...new Set(formattedPosts.flatMap((entry) => entry.data.tags ?? []))];
uniqueTags.sort((a, b) => a.localeCompare(b));

const posts = formattedPosts.map((entry) => ({
	slug: entry.id,
	title: entry.data.title,
	tags: entry.data.tags ?? [],
	year: new Date(entry.data.date).getFullYear(),
}));

const title = 'Writing';
const description =
	'Essays on design, code, philosophy, and the examined life. Published here since 2007.';
---

<BaseLayout title={title} description={description}>
	<!-- Page title -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-16 pt-32">
		<PageHeading>Writing</PageHeading>
	</div>

	<!-- Content sections -->
	<div class="mx-auto flex w-full max-w-[1440px] flex-col gap-16 px-8 pb-32">
		<!-- INTRODUCTION -->
		<PageSection label="Introduction">
			<p class="text-3 max-w-xl leading-relaxed">
				Since 2007 I have been writing here — essays on design, code, philosophy,
				minimalism, Japan, and the life of the mind. A collection of essays on <TextLink
					href="https://www.kogakure.de/en/">Ninja and Ninjutsu</TextLink
				> grew into a book. Medium featured <TextLink href="/attention/">one essay</TextLink
				> as their recommendation of the day. I also write <TextLink href="/haiku/"
					>Haiku</TextLink
				>.
			</p>
		</PageSection>

		<!-- FILTER + ESSAYS (interactive, client-side) -->
		<WritingPage client:load allTags={uniqueTags} posts={posts} />
	</div>
</BaseLayout>
