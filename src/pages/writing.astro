---
import type { CollectionEntry } from 'astro:content';
type Journal = CollectionEntry<'journal'>;
import { getCollection } from 'astro:content';

import { formatPosts } from '../utils';

import BaseLayout from '../layouts/BaseLayout.astro';
import PageSection from '../components/PageSection.astro';
import WritingPage from '../components/WritingPage';

const allPosts = await getCollection('journal', ({ data }: Journal) => !data.draft);
const formattedPosts = formatPosts(allPosts, {});

const uniqueTags = [...new Set(formattedPosts.flatMap((entry) => entry.data.tags ?? []))];
uniqueTags.sort((a, b) => a.localeCompare(b));

const posts = formattedPosts.map((entry) => ({
	slug: entry.id,
	title: entry.data.title,
	tags: entry.data.tags ?? [],
	year: new Date(entry.data.date).getFullYear(),
}));

const title = 'Writing';
const description =
	'Essays on design, code, philosophy, and the examined life. Published here since 2007.';
---

<BaseLayout title={title} description={description}>
	<!-- Page title -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pt-32 pb-16">
		<h1
			class="font-display italic text-[clamp(3.5rem,7.5vw,9rem)] font-bold leading-[0.92] tracking-tight text-sumi dark:text-washi"
		>
			Writing
		</h1>
	</div>

	<!-- Content sections -->
	<div class="mx-auto w-full max-w-[1440px] px-8 flex flex-col gap-16 pb-32">
		<!-- INTRODUCTION -->
		<PageSection label="Introduction">
			<p class="max-w-xl text-3 leading-relaxed">
				Since 2007 I have been writing here — essays on design, code, philosophy, minimalism,
				Japan, and the life of the mind. A collection of essays on <a
					class="underline hover:opacity-60 transition-opacity"
					href="https://www.kogakure.de/en/">Ninja and Ninjutsu</a
				> grew into a book. Medium featured <a
					class="underline hover:opacity-60 transition-opacity"
					href="/attention/">one essay</a
				> as their recommendation of the day. I also write <a
					class="underline hover:opacity-60 transition-opacity"
					href="/haiku/">Haiku</a
				>.
			</p>
		</PageSection>

		<!-- FILTER + ESSAYS (interactive, client-side) -->
		<WritingPage client:load allTags={uniqueTags} posts={posts} />
	</div>
</BaseLayout>
