---
import BaseLayout from '../layouts/BaseLayout.astro';
import MoreLink from '../components/ui/MoreLink';
import PageHeading from '../components/ui/PageHeading';
import PageSection from '../components/ui/PageSection';
import SectionLabel from '../components/ui/SectionLabel';
import TextLink from '../components/ui/TextLink';

const title = 'About';
const description =
	"I'm Stefan Imhoff—design engineer, writer, and observer—based in Hamburg, Germany.";
---

<BaseLayout title={title} description={description}>
	<!-- Page title -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-16 pt-32">
		<PageHeading>About</PageHeading>
	</div>

	<!-- Content sections -->
	<div class="mx-auto flex w-full max-w-[1440px] flex-col gap-16 px-8 pb-32">
		<!-- INTRODUCTION: single portrait using grid rows across breakpoints -->
		<!-- Mobile: 3-col grid, portrait row-1 spanning 2 cols with left bleed -->
		<!-- Tablet: 6-col grid, portrait row-1 spanning cols 3-6, label+bio in row-2 -->
		<!-- Desktop: 3-track grid [160px_1fr_200px], all items in row-1 -->
		<!-- Mobile: 3-col/16px gutters | Tablet: 6-col/24px gutters | Desktop: 12-col/32px gutters -->
		<section
			class="grid grid-cols-3 gap-x-4 gap-y-6 md:grid-cols-6 md:gap-x-6 md:gap-y-8 lg:grid-cols-12 lg:gap-x-8 lg:gap-y-0"
		>
			<!-- Portrait: row-1 always; mobile 2-cols bleed-left; tablet cols 4-6 rows 1-2; desktop cols 10-12 -->
			<div
				class="col-span-2 row-start-1 -ml-8 self-start md:col-span-3 md:col-start-4 md:row-span-2 md:row-start-1 md:ml-0 lg:col-span-3 lg:col-start-10 lg:row-span-1 lg:row-start-1"
			>
				<img
					src="/assets/images/portrait-stefan-imhoff-2026.webp"
					alt="Portrait of Stefan Imhoff"
					class="rounded-2 w-full object-cover md:-scale-x-100"
					loading="lazy"
					decoding="async"
				/>
			</div>
			<!-- Label: mobile row-2 full-width; tablet col 1-3 row-1; desktop col 1-2 -->
			<div
				class="col-span-3 row-start-2 md:col-span-3 md:col-start-1 md:row-start-1 md:pt-[0.35em] lg:col-span-2 lg:col-start-1 lg:row-start-1"
			>
				<SectionLabel>Introduction</SectionLabel>
			</div>
			<!-- Bio: mobile row-3 full-width; tablet col 1-3 row-2; desktop col 3-9 -->
			<div
				class="col-span-3 row-start-3 min-w-0 md:col-span-3 md:col-start-1 md:row-start-2 lg:col-span-7 lg:col-start-3 lg:row-start-1"
			>
				<div class="text-3 flex max-w-xl flex-col gap-5 leading-relaxed">
					<p>
						I am <strong>Stefan Imhoff</strong>—design engineer, writer, and
						observer—based in Hamburg, Germany.
					</p>
					<p>
						I find meaning in ideas. Books on philosophy, science, and economics. <TextLink
							href="https://raindrop.io/kogakure/podcasts-24118384">Podcasts</TextLink
						>. <TextLink href="https://www.themoviedb.org/u/kogakure/favorites"
							>Films</TextLink
						>—particularly <TextLink
							href="https://www.themoviedb.org/list/8216385-korea?view=grid"
							>Korean</TextLink
						> and <TextLink
							href="https://www.themoviedb.org/list/106001-japan?view=grid"
							>Japanese</TextLink
						> cinema and drama. I believe humans understand the world through narrative,
						and I try to contribute to that—through <TextLink href="/journal/"
							>essays</TextLink
						>, sketchnotes, <TextLink href="/haiku/">Haiku</TextLink>, and a free <TextLink
							href="https://www.kogakure.de/en/">book on Ninja and Ninjutsu</TextLink
						>.
					</p>
					<p>
						Outside the screen: <TextLink href="https://hamburg.stefanimhoff.de/"
							>walking and cycling through Hamburg</TextLink
						>, calisthenics, ink sketching and watercolour, and a persistent attention
						to the small things—the quality of light through leaves, the sound of a
						storm, the particular silence after it passes.
					</p>
					<p>
						I practice minimalism, draw from Stoic philosophy, and hold Japanese
						aesthetics close—especially the principle of <em>shibui</em> (渋い): quiet beauty
						that reveals itself slowly.
					</p>
				</div>
			</div>
		</section>

		<!-- LINKS -->
		<PageSection label="Links">
			<div class="flex flex-col gap-2">
				<MoreLink href="/life-rules/" text="Rules and principles I live by" />
				<MoreLink href="/tools/" text="Tools I use" />
				<MoreLink href="/now/" text="What I am doing now" />
			</div>
		</PageSection>
	</div>
</BaseLayout>
