---
import GridLayout from '@/layouts/GridLayout.astro';

import AmazonBook from '@/components/content/AmazonBook';
import ColorStack from '@/components/content/ColorStack';
import ColorSwatchPrimary from '@/components/content/ColorSwatchPrimary';
import PageTitle from '@/components/site/PageTitle.astro';

import { Content as Intro } from '@/text/traditional-colors-of-japan/intro.mdx';
import colors from '@/data/colors-japan.json';

import { mapping } from '@/mdx-components';

const title = 'The Traditional Colors of Japan';
const description =
	'I took the time and converted all colors in the book “Traditional Colors of Japan” by Nobyoshi Hamada into an ASE file free to download.';
---

<GridLayout title={title} description={description} grid="wide" class="grid" innerGrid>
	<PageTitle class="col-end-19 mbe-0 col-start-1 row-start-1"
		>The Traditional Colors of&nbsp;Japan</PageTitle
	>

	<article class="col-end-17 col-start-1 grid md:col-end-8 xl:content-center">
		<Intro components={mapping} />
	</article>

	<article class="col-end-17 col-start-1 flex grid-cols-2 md:col-start-9 md:justify-end">
		<AmazonBook
			alt="The Traditional Colors of Japan"
			asin="475624100X"
			className="max-w-75 me-[1.5vw] [&_img]:self-end"
		/>
		<AmazonBook
			alt="Traditional Japanese Color Palette"
			asin="475624114X"
			className="max-w-75 ms-[1.5vw] [&_img]:self-end"
		/>
	</article>

	<ColorStack className="grid-cols-[repeat(auto-fill,minmax(220px,1fr))]">
		{
			colors.map(({ name, kanji, hiragana, description, color }) => (
				<ColorSwatchPrimary
					color={color}
					name={name}
					kanji={kanji}
					hiragana={hiragana}
					description={description}
				/>
			))
		}
	</ColorStack>
</GridLayout>
