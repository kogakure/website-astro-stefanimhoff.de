---
import GridLayout from '@/layouts/GridLayout.astro';

import PageTitle from '@/components/site/PageTitle.astro';
import Verse from '@/components/content/Verse';

import { Content as Haiku } from '@/content/text/404/haiku.mdx';
import { mapping } from '@/mdx-components';

const title = 'Error 404';
const description = 'Page not found.';
---

<GridLayout
	class="grid"
	description={description}
	grid="wide"
	innerGrid
	nofollow={true}
	noindex={true}
	title={title}
>
	<PageTitle>Not Found.</PageTitle>
	<Verse
		className="col-end-17 text-3 mbe-10 mbs-10 z-10 col-start-1 row-start-2 italic md:col-start-3 md:col-end-9"
		variant="left"
	>
		<Haiku components={mapping} />
	</Verse>
	<span
		aria-hidden="true"
		class="text-9 col-start-10 col-end-13 row-start-1 row-end-3 font-black text-black/5 dark:text-white/5"
		role="img"
	>
		404
	</span>
</GridLayout>

<style>
	span {
		line-height: 0.6;
		user-select: none;
		writing-mode: vertical-lr;
	}
</style>
