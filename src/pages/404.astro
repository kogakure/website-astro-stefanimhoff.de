---
import BaseLayout from '@/layouts/BaseLayout.astro';

import MoreLink from '@/components/ui/MoreLink';
import SectionLabel from '@/components/ui/SectionLabel';
import Text from '@/components/ui/Text';
import Title from '@/components/ui/Title';
import Verse from '@/components/content/Verse';

import { Content as Haiku } from '@/content/text/404/haiku.mdx';
import { mapping } from '@/mdx-components';

const title = 'Error 404';
const description = 'Page not found.';
---

<BaseLayout description={description} nofollow={true} noindex={true} title={title}>
	<!-- Hero: kanji left, text stack right -->
	<div
		class="max-w-360 pli-8 pbs-32 mx-auto grid w-full grid-cols-3 gap-x-4 gap-y-0 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8"
	>
		<div class="col-span-3 flex items-end md:col-span-2 xl:col-span-4">
			<span
				aria-hidden="true"
				class="font-japanese text-beni dark:text-beni-light select-none text-[clamp(8rem,28vw,22rem)] leading-none"
				lang="ja"
			>
				迷
			</span>
		</div>

		<div
			class="pbe-4 col-span-3 flex flex-col justify-end md:col-span-4 xl:col-span-6 xl:col-start-7"
		>
			<SectionLabel as="p">Error · 404</SectionLabel>
			<Title className="mbs-2 text-[clamp(2.5rem,6vw,4.5rem)] leading-[0.95]">
				Not Found.
			</Title>
			<Text as="p" className="text-2 text-nezumi mbe-0 mbs-2">
				<span lang="ja-Latn">mayoi</span> · lost · astray
			</Text>
		</div>
	</div>

	<!-- Haiku + CTA -->
	<div
		class="max-w-360 pli-8 pbe-32 pbs-16 mx-auto grid w-full grid-cols-3 gap-x-4 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8"
	>
		<div class="col-span-3 md:col-span-4 md:col-start-2 xl:col-span-6 xl:col-start-4">
			<Verse variant="left">
				<Haiku components={mapping} />
			</Verse>
			<div class="mbs-8">
				<MoreLink href="/" text="Return home" />
			</div>
		</div>
	</div>
</BaseLayout>
