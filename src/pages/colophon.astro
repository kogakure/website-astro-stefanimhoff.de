---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageTitle from '@/components/site/PageTitle.astro';
import PageSection from '@/components/ui/PageSection';
import Text from '@/components/ui/Text';
import TextLink from '@/components/ui/TextLink';

const title = 'Colophon';
const description = 'How this website was designed and built.';
---

<BaseLayout title={title} description={description}>
	<PageTitle>Colophon</PageTitle>

	<div class="max-w-360 mx-auto flex w-full flex-col gap-16 px-8 pb-32">
		<PageSection label="Design">
			<div class="flex flex-col gap-5 leading-relaxed">
				<Text className="mbe-0">
					Designed in <TextLink href="https://www.affinity.studio/">Affinity</TextLink>,
					guided by the Japanese aesthetic of <em>shibui</em> (渋い)—a restrained, understated
					beauty rooted in the Muromachi period. Further reading: <TextLink
						href="/new-website-2020-inspiration/">the inspiration</TextLink
					> and <TextLink href="/new-website-2020-design/">the design process</TextLink>.
				</Text>
				<Text className="mbe-0">
					Typography uses the variable typefaces <TextLink
						href="https://productiontype.com/family/boska">Boska</TextLink
					> by Production Type and <TextLink
						href="https://www.fontshare.com/fonts/switzer">Switzer</TextLink
					> by Fontshare, scaled on the golden ratio and responsive to viewport width.
				</Text>
				<Text className="mbe-0">
					Cover images and the portrait were generated with <TextLink
						href="https://stability.ai/">Stable Diffusion</TextLink
					>, <TextLink href="https://blackforestlabs.ai/">FLUX</TextLink>, <TextLink
						href="https://github.com/lllyasviel/ControlNet">ControlNet</TextLink
					>, <TextLink href="https://platform.openai.com/docs/models/gpt-image-1"
						>GPT Image 1</TextLink
					>, <TextLink href="https://deepmind.google/models/gemini-image/pro/"
						>Gemini 3 Pro Image</TextLink
					>, and <TextLink href="https://www.affinity.studio/">Affinity</TextLink>. Icons
					are from <TextLink href="https://remixicon.com/">Remix Icon</TextLink> by <TextLink
						href="https://github.com/xiaochunjimmy">Jimmy Cheung</TextLink
					> and <TextLink href="https://github.com/wendygaoyuan">Wendy Gao</TextLink>.
				</Text>
			</div>
		</PageSection>

		<PageSection label="Technology">
			<div class="flex flex-col gap-5 leading-relaxed">
				<Text className="mbe-0">
					Built with <TextLink href="https://astro.build/">Astro</TextLink>. Written in <TextLink
						href="https://neovim.io/">Neovim</TextLink
					> with <TextLink href="https://github.com/features/copilot"
						>GitHub Copilot</TextLink
					>, <TextLink href="https://code.claude.com/">Claude Code</TextLink>, and <TextLink
						href="https://www.raycast.com/pro">Raycast AI</TextLink
					>. Components in Astro and <TextLink href="https://react.dev/">React</TextLink>.
					Content in <TextLink href="https://mdxjs.com/">MDX</TextLink>. Styled with <TextLink
						href="https://tailwindcss.com/">Tailwind CSS</TextLink
					>. Search via <TextLink href="https://pagefind.app/">Pagefind</TextLink>.
					Self-hosted with <TextLink href="https://coolify.io/">Coolify</TextLink>.
				</Text>
				<Text className="mbe-0">
					Source code is on <TextLink
						href="https://github.com/kogakure/website-astro-stefanimhoff.de"
						>GitHub</TextLink
					>. You are welcome to learn from it. Build your own things.
				</Text>
				<Text className="text-2 text-hai mbe-0">Last updated: December 15th, 2025</Text>
			</div>
		</PageSection>
	</div>
</BaseLayout>
