---
import type { CollectionEntry } from 'astro:content';
type Journal = CollectionEntry<'journal'>;
import { getCollection, render } from 'astro:content';

import { site } from '../data/site';

import { formatPosts, sortByDate } from '../utils';
import { dateToFormat, dateToISO, wordCount } from '../utils';

import { mapping } from '../mdx-components';

import BaseLayout from '../layouts/BaseLayout.astro';
import Tag from '../components/Tag';

export async function getStaticPaths() {
	const journalEntries = await getCollection('journal', ({ data }: Journal) => !data.draft);
	const numberOfPages = journalEntries.length;
	const formattedJournalEntries: Journal[] = formatPosts(journalEntries, { sortOrder: 'asc' });

	return formattedJournalEntries.map((entry, index) => ({
		params: { slug: entry.id },
		props: {
			entry,
			next:
				index + 1 === numberOfPages
					? { id: null, data: null }
					: formattedJournalEntries[index + 1],
			prev: index === 0 ? { id: null, data: null } : formattedJournalEntries[index - 1],
		},
	}));
}

const { entry, prev, next } = Astro.props;
const entryId = entry.id;
const {
	Content,
	remarkPluginFrontmatter: { minutesRead },
} = await render(entry);

const seriesEntries: Journal[] = await getCollection('journal', ({ data }: Journal) => {
	return data.series === entry.data.series && !data.draft;
});

seriesEntries.sort(sortByDate).reverse();

const title = entry.data.title;
const subtitle = entry.data.subtitle;
const description = entry.data.description;

const schema = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: entry.data.title,
	description: entry.data.description,
	datePublished: entry.data.date,
	dateModified: entry.data.updated,
	image: [
		entry.data.cover ? site.url + entry.data.cover : `${site.url}/assets/images/og/bonsai.jpg`,
	],
	author: [
		{
			'@type': 'Person',
			name: entry.data.author || site.author,
			url: `${site.url}/about`,
		},
	],
	mainEntityOfPage: {
		'@type': 'webPage',
		id: `${site.url}/${entryId}/`,
	},
});
---

<BaseLayout
	cover={entry.data.cover}
	description={description}
	nofollow={entry.data.nofollow}
	noindex={entry.data.noindex}
	title={subtitle ? `${title}: ${subtitle}` : title}
>
	<!-- Page title -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pt-32 pb-12">
		<h1
			class="font-display italic text-[clamp(3rem,6vw,7rem)] font-bold leading-[0.92] tracking-tight text-sumi dark:text-washi"
		>
			{title}
		</h1>
		{
			subtitle && (
				<p class="mt-4 text-3 text-hai italic">{subtitle}</p>
			)
		}
	</div>

	<!-- Cover image -->
	{
		entry.data.cover && (
			<div class="mx-auto w-full max-w-[1440px] px-8 pb-12">
				<img
					src={entry.data.cover}
					alt={title}
					class="w-full rounded-2 object-cover"
					loading="eager"
					decoding="async"
				/>
			</div>
		)
	}

	<!-- Article layout: meta + content -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-32">
		<div class="grid gap-6 md:grid-cols-[160px_1fr] md:gap-16">
			<!-- Meta column -->
			<aside>
				<div class="flex flex-col gap-4 text-2 text-hai sticky top-8">
					<div>
						<time datetime={dateToISO(entry.data.date)}>
							{dateToFormat(entry.data.date)}
						</time>
					</div>
					<div>
						{Math.round(minutesRead)} min read
					</div>
					{
						entry.data.tags && entry.data.tags.length > 0 && (
							<div class="flex flex-wrap gap-2 mt-2">
								{entry.data.tags
									.sort((a: string, b: string) => a.localeCompare(b))
									.map((t: string) => (
										<Tag href={`/writing/?tag=${t}`}>{t}</Tag>
									))}
							</div>
						)
					}
				</div>
			</aside>

			<!-- Article body -->
			<article class="journal-post min-w-0">
				{
					entry.data.series && seriesEntries.length > 1 && (
						<div class="mb-8 rounded-2 border border-shibui-200 dark:border-shibui-800 p-4">
							<p class="text-2 tracking-widest uppercase text-hai mb-3">Series</p>
							<ol class="flex flex-col gap-1">
								{seriesEntries.map((item) => (
									<li class="text-3">
										{entryId === item.id ? (
											<em class="font-bold text-sumi dark:text-washi">{item.data.title}</em>
										) : (
											<a class="text-beni hover:opacity-60 transition-opacity" href={`/${item.id}/`}>
												{item.data.title}
											</a>
										)}
									</li>
								))}
							</ol>
						</div>
					)
				}
				<Content components={mapping} />
				{
					entry.data.updated && (
						<footer class="mt-12 text-2 text-hai">
							<span class="font-bold">Last Updated:</span>{' '}
							<time datetime={dateToISO(entry.data.updated)}>
								{dateToFormat(entry.data.updated)}
							</time>
						</footer>
					)
				}
			</article>
		</div>
	</div>

	<!-- Prev/Next navigation -->
	{
		(prev.id || next.id) && (
			<nav class="mx-auto w-full max-w-[1440px] px-8 pb-16 grid grid-cols-2 gap-8 border-t border-shibui-200 dark:border-shibui-800 pt-8">
				<div>
					{prev.id && (
						<a class="group flex flex-col gap-1 hover:opacity-60 transition-opacity" href={`/${prev.id}/`}>
							<span class="text-2 tracking-widest uppercase text-hai">Previous</span>
							<span class="text-3 font-bold text-sumi dark:text-washi">{prev.data.title}</span>
						</a>
					)}
				</div>
				<div class="text-right">
					{next.id && (
						<a class="group flex flex-col gap-1 hover:opacity-60 transition-opacity" href={`/${next.id}/`}>
							<span class="text-2 tracking-widest uppercase text-hai">Next</span>
							<span class="text-3 font-bold text-sumi dark:text-washi">{next.data.title}</span>
						</a>
					)}
				</div>
			</nav>
		)
	}
</BaseLayout>

<script type="application/ld+json" set:html={schema} />

<style is:global>
	@reference "../styles/global.css";

	.journal-post {
		& p {
			@apply text-3 leading-relaxed mb-5 max-w-[65ch];
		}

		& h2 {
			@apply font-display text-5 font-bold tracking-tight text-sumi dark:text-washi mt-16 mb-4;
		}

		& h3 {
			@apply text-3 font-bold text-sumi dark:text-washi mt-10 mb-2;
		}

		& h4,
		& h5,
		& h6 {
			@apply text-3 font-bold text-sumi dark:text-washi mt-8 mb-2;
		}

		& ul,
		& ol {
			@apply text-3 leading-relaxed mb-5 max-w-[65ch];
		}

		& ul {
			@apply list-disc pl-5;
		}

		& ol {
			@apply list-decimal pl-5;
		}

		& li {
			@apply mb-1;
		}

		& a {
			@apply text-beni hover:opacity-60 transition-opacity underline;
		}

		& strong {
			@apply font-bold;
		}

		& em {
			@apply italic;
		}

		& hr {
			@apply border-shibui-300 dark:border-shibui-700 my-12 max-w-[65ch];
		}

		& blockquote {
			@apply border-l-2 border-beni pl-4 italic text-hai mb-5 max-w-[65ch];
		}

		& pre {
			@apply overflow-auto rounded-2 p-4 font-mono text-code mb-8;
		}

		& code:not(pre code) {
			@apply font-mono text-code bg-shibui-200 dark:bg-shibui-800 px-1 rounded;
		}

		& figure {
			@apply mb-8;
		}

		& img {
			@apply rounded-2 w-full;
		}

		/** Footnotes */
		.footnotes {
			@apply mt-12 border-t border-shibui-200 dark:border-shibui-800 pt-8;
		}

		.footnotes ol {
			@apply text-2 text-hai list-none p-0 flex flex-col gap-2;
		}

		.footnotes li {
			@apply flex gap-2;
		}

		.footnotes p {
			@apply !mb-0 !text-2 !text-hai;
		}

		.footnotes a {
			@apply !text-beni;
		}

		[data-footnote-ref] {
			@apply relative font-light not-italic !text-beni no-underline mis-[0.2em];
		}
	}
</style>
