---
import type { CollectionEntry } from 'astro:content';
type Journal = CollectionEntry<'journal'>;
import { getCollection, render } from 'astro:content';

import { site } from '@/data/site';

import { formatPosts, sortByDate, dateToFormat, dateToISO, wordCount } from '@/utils';

import { mapping } from '@/mdx-components';

import BaseLayout from '@/layouts/BaseLayout.astro';
import ListItem from '@/components/ui/ListItem';
import OrderedList from '@/components/ui/OrderedList';
import UnorderedList from '@/components/ui/UnorderedList';
import PageTitle from '@/components/site/PageTitle.astro';
import SectionLabel from '@/components/ui/SectionLabel';
import Text from '@/components/ui/Text';
import TextLink from '@/components/ui/TextLink';

export async function getStaticPaths() {
	const journalEntries = await getCollection('journal', ({ data }: Journal) => !data.draft);
	const numberOfPages = journalEntries.length;
	const formattedJournalEntries: Journal[] = formatPosts(journalEntries, { sortOrder: 'asc' });

	return formattedJournalEntries.map((entry, index) => ({
		params: { slug: entry.id },
		props: {
			entry,
			next:
				index + 1 === numberOfPages
					? { id: null, data: null }
					: formattedJournalEntries[index + 1],
			prev: index === 0 ? { id: null, data: null } : formattedJournalEntries[index - 1],
		},
	}));
}

const { entry, prev, next } = Astro.props;
const entryId = entry.id;
const {
	Content,
	remarkPluginFrontmatter: { minutesRead },
} = await render(entry);

const words = wordCount(entry.body ?? '');

const seriesEntries: Journal[] = await getCollection('journal', ({ data }: Journal) => {
	return data.series === entry.data.series && !data.draft;
});

seriesEntries.sort(sortByDate).reverse();

const title = entry.data.title;
const subtitle = entry.data.subtitle;
const description = entry.data.description;

const schema = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: entry.data.title,
	description: entry.data.description,
	datePublished: entry.data.date,
	dateModified: entry.data.updated,
	image: [
		entry.data.cover ? site.url + entry.data.cover : `${site.url}/assets/images/og/bonsai.jpg`,
	],
	author: [
		{
			'@type': 'Person',
			name: entry.data.author || site.author,
			url: `${site.url}/about`,
		},
	],
	mainEntityOfPage: {
		'@type': 'webPage',
		id: `${site.url}/${entryId}/`,
	},
});
---

<BaseLayout
	cover={entry.data.cover}
	description={description}
	nofollow={entry.data.nofollow}
	noindex={entry.data.noindex}
	title={subtitle ? `${title}: ${subtitle}` : title}
>
	<PageTitle
		class="pb-6"
		titleClass="text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.0] tracking-[-0.04em] font-bold"
		>{title}</PageTitle
	>

	{
		subtitle && (
			<div class="max-w-360 mx-auto grid w-full grid-cols-3 gap-x-4 px-8 pb-8 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8">
				<Text className="col-span-3 text-[clamp(1.25rem,2.083vw,1.875rem)] leading-[1.3] text-sumi dark:text-washi tracking-[-0.05em] mbe-0 md:col-span-6 xl:col-span-8 xl:col-start-2">
					{subtitle}
				</Text>
			</div>
		)
	}

	{
		entry.data.cover && (
			<div class="max-w-360 mx-auto grid w-full grid-cols-3 gap-x-4 px-8 pb-12 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8">
				<div class="col-span-3 md:col-span-6 xl:col-span-11 xl:col-start-2">
					<img
						src={entry.data.cover}
						alt={title}
						class="rounded-2 w-full object-cover"
						loading="eager"
						decoding="async"
						style="view-transition-name: post-cover"
					/>
				</div>
			</div>
		)
	}

	<!-- Article layout: meta sidebar + content -->
	<div
		class:list={[
			'max-w-360 mx-auto grid w-full grid-cols-3 gap-x-4 gap-y-8 px-8 pb-32 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8',
			!entry.data.cover && 'pt-24',
		]}
	>
		<!-- Left sidebar (TOC placeholder, populated in SI-mebe) -->
		<aside class="col-span-3 md:col-span-6 xl:col-span-2 xl:col-start-2"></aside>

		<!-- Article body -->
		<article
			class="journal-post col-span-3 min-w-0 md:col-span-4 md:col-start-2 xl:col-span-6 xl:col-start-4"
		>
			{
				entry.data.series && seriesEntries.length > 1 && (
					<div class="rounded-2 border-usuzumi dark:border-nezumi mb-8 border p-4">
						<SectionLabel as="p" className="mbe-3">
							Series
						</SectionLabel>
						<OrderedList className="flex flex-col gap-1 mbe-0 pis-0">
							{seriesEntries.map((item) => (
								<ListItem className="mbe-1">
									{entryId === item.id ? (
										<em class="text-sumi dark:text-washi font-bold">
											{item.data.title}
										</em>
									) : (
										<TextLink href={`/${item.id}/`}>{item.data.title}</TextLink>
									)}
								</ListItem>
							))}
						</OrderedList>
					</div>
				)
			}
			<Content components={mapping} />
			{
				entry.data.updated && (
					<footer class="text-2 text-hai mt-12">
						<span class="font-bold">Last Updated:</span>{' '}
						<time datetime={dateToISO(entry.data.updated)}>
							{dateToFormat(entry.data.updated)}
						</time>
					</footer>
				)
			}
		</article>

		<!-- Right meta sidebar -->
		<aside class="col-span-3 md:col-span-6 xl:col-span-2 xl:col-start-10">
			<div class="sticky top-8 flex flex-col gap-6">
				<SectionLabel as="p" className="mbe-0">Meta</SectionLabel>
				<UnorderedList className="text-sumi dark:text-washi">
					<ListItem>
						<time datetime={dateToISO(entry.data.date)}>
							{dateToFormat(entry.data.date, 'D MMMM YYYY')}
						</time>
					</ListItem>
					<ListItem>
						{words.toLocaleString('en-US')} words · {Math.round(minutesRead)} min read
					</ListItem>
				</UnorderedList>
			</div>
		</aside>
	</div>

	<!-- Prev/Next navigation -->
	{
		(prev.id || next.id) && (
			<nav class="border-usuzumi dark:border-nezumi max-w-360 mx-auto grid w-full grid-cols-2 gap-8 border-t px-8 pb-16 pt-8">
				<div>
					{prev.id && (
						<a
							class="group flex flex-col gap-1 transition-opacity hover:opacity-60"
							href={`/${prev.id}/`}
						>
							<span class="text-2 text-hai uppercase tracking-widest">Previous</span>
							<span class="text-3 text-sumi dark:text-washi font-bold">
								{prev.data.title}
							</span>
						</a>
					)}
				</div>
				<div class="text-right">
					{next.id && (
						<a
							class="group flex flex-col gap-1 transition-opacity hover:opacity-60"
							href={`/${next.id}/`}
						>
							<span class="text-2 text-hai uppercase tracking-widest">Next</span>
							<span class="text-3 text-sumi dark:text-washi font-bold">
								{next.data.title}
							</span>
						</a>
					)}
				</div>
			</nav>
		)
	}
</BaseLayout>

<script is:inline type="application/ld+json" set:html={schema} />

<style is:global>
	@reference "../styles/global.css";

	.journal-post {
		& p {
			@apply text-3 mbe-8 mbs-0 leading-relaxed;
		}

		& h2 {
			@apply text-5 text-sumi dark:text-washi mbe-4 mbs-16 font-bold;
			letter-spacing: -0.05em;
		}

		& h3 {
			@apply text-4 text-sumi dark:text-washi mbe-2 mbs-10 font-bold;
			letter-spacing: -0.02em;
		}

		& h4,
		& h5,
		& h6 {
			@apply text-3 text-sumi dark:text-washi mbe-2 mbs-8 font-bold;
		}

		& ul,
		& ol {
			@apply text-3 mbe-8 leading-relaxed;
		}

		& ul {
			@apply pis-5 md:pis-0 list-disc;
		}

		& ol {
			@apply pis-5 md:pis-0 list-decimal;
		}

		& li {
			@apply mbe-1;
		}

		& a {
			@apply text-beni underline transition-opacity hover:opacity-60;
		}

		& strong {
			@apply font-bold;
		}

		& em {
			@apply italic;
		}

		& hr {
			@apply border-usuzumi dark:border-nezumi mbe-12 mbs-12;
		}

		& blockquote {
			@apply border-beni text-hai mbe-8 pis-4 border-s-2 italic;
		}

		& pre {
			@apply rounded-2 text-code mbe-8 overflow-auto p-4 font-mono;
		}

		& code:not(pre code) {
			@apply text-code bg-kiri dark:bg-yoru rounded px-1 font-mono;
		}

		& figure {
			@apply mbe-8;
		}

		& img {
			@apply rounded-2 w-full;
		}

		/** Footnotes */
		.footnotes {
			@apply border-usuzumi dark:border-nezumi mbs-12 pbs-8 border-t;
		}

		.footnotes ol {
			@apply text-2 text-hai flex list-none flex-col gap-2 p-0;
		}

		.footnotes li {
			@apply flex gap-2;
		}

		.footnotes p {
			@apply text-2! text-hai! mbe-0!;
		}

		.footnotes a {
			@apply text-beni!;
		}

		[data-footnote-ref] {
			@apply text-beni! relative ms-[0.2em] font-light not-italic no-underline;
		}
	}
</style>
