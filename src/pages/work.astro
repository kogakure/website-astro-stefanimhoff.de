---
import type { CollectionEntry } from 'astro:content';
type Projects = CollectionEntry<'projects'>;
import { getCollection } from 'astro:content';

import { sortBySortKey } from '../utils';

import BaseLayout from '../layouts/BaseLayout.astro';
import DisplayHeadline from '../components/ui/DisplayHeadline';
import MoreLink from '../components/ui/MoreLink';
import PageHeading from '../components/ui/PageHeading';

const allProjects: Projects[] = await getCollection('projects');
const projects = allProjects.sort(sortBySortKey);

const title = 'Work';
const description = "I'm a Design Engineer. These are selected projects from the last two decades.";
---

<BaseLayout title={title} description={description}>
	<!-- Page title -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-16 pt-32">
		<PageHeading>Work</PageHeading>
	</div>

	<!-- Introduction -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-16">
		<p class="text-3 text-hai max-w-xl leading-relaxed">
			I am a design engineer by discipline. In previous chapters: editorial design, 3D
			animation, and a period spent making Flash animations and multimedia CD-ROMs that no
			longer exist anywhere. I have always believed in working across domains. A specialist in
			one thing tends to miss the connections.
		</p>
		<p class="text-3 text-hai mt-4 max-w-xl leading-relaxed">
			These are selected projects from the last two decades.
		</p>
	</div>

	<!-- Project list -->
	<div class="mx-auto flex w-full max-w-[1440px] flex-col gap-24 px-8 pb-32">
		{
			projects.map((project) => (
				<article class="flex flex-col gap-6">
					{/* Project image */}
					{project.data.image && (
						<div class="rounded-2 overflow-hidden">
							<img
								src={project.data.image.src}
								alt={project.data.title}
								class="w-full object-cover"
								loading="lazy"
								decoding="async"
							/>
						</div>
					)}

					{/* Project info */}
					<div class="grid gap-6 md:grid-cols-[160px_1fr] md:gap-16">
						<div>
							<p class="text-2 text-hai italic tracking-widest">
								{project.data.categories.join(' / ')}
							</p>
						</div>
						<div class="min-w-0">
							<DisplayHeadline className="mb-3">{project.data.title}</DisplayHeadline>
							{project.data.intro && (
								<p class="text-3 max-w-xl leading-relaxed">{project.data.intro}</p>
							)}
							{project.data.more && (
								<MoreLink
									className="mt-4"
									href={project.data.more.link}
									text={project.data.more.text || 'View project'}
								/>
							)}
						</div>
					</div>
				</article>
			))
		}
	</div>
</BaseLayout>
