---
import type { CollectionEntry } from 'astro:content';
type JournalType = CollectionEntry<'journal'>;
import { getCollection } from 'astro:content';

import { formatPosts } from '../utils';

import BaseLayout from '../layouts/BaseLayout.astro';
import DashList from '../components/ui/DashList';
import DashListItem from '../components/ui/DashListItem';
import Link from '../components/ui/Link';
import MoreLink from '../components/ui/MoreLink';
import PageHeading from '../components/ui/PageHeading';
import PageSection from '../components/ui/PageSection';
import Text from '../components/ui/Text';

const allPosts = await getCollection('journal', ({ data }: JournalType) => !data.draft);
const latestPosts = formatPosts(allPosts, { limit: 9 });

const title = 'Stefan Imhoff';
const description = 'Design Engineer from Hamburg, Germany';
---

<BaseLayout title={title} description={description}>
	<!-- Hero -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-32 pt-32">
		<PageHeading className="hero-title leading-[1.05]">
			Stefan Imhoff <em class="font-display font-normal">is a</em><br
				class="hidden lg:block"
			/>
			Design Engineer<br class="hidden lg:block" />
			<span>
				<em class="font-display font-normal">from</em>
				<span class="whitespace-nowrap">Hamburg<span class="text-beni ml-4">—</span></span>
			</span>
		</PageHeading>
	</div>

	<!-- Sections above marquee -->
	<div class="mx-auto mb-16 flex w-full max-w-[1440px] flex-col gap-16 px-8">
		<!-- ABOUT -->
		<PageSection label="About">
			<Text className="mbe-5 max-w-xl leading-[1.2]">
				Nearly two decades at the intersection of design and code. Guided by simplicity,
				structure, and the discipline of leaving things out.
			</Text>
			<MoreLink href="/about/" text="About" />
		</PageSection>

		<!-- WORK -->
		<PageSection label="Work">
			<Text className="mbe-5 max-w-xl leading-[1.2]">
				I build interfaces that hold up under scrutiny — design systems, component
				libraries, and the invisible layer of decisions that makes a product coherent. For
				most of the last decade, that work was at XING, Europe's leading professional
				network.
			</Text>
			<MoreLink href="/work/" text="See selected work" />
		</PageSection>
	</div>

	<!-- Haiku marquee band -->
	<div class="marquee-band my-4 overflow-hidden py-3" aria-hidden="true">
		<div class="marquee-track flex whitespace-nowrap">
			<span
				class="marquee-content font-japanese text-beni px-12 font-bold not-italic"
				style="font-size: clamp(3rem, 6vw, 7.5rem);"
			>
				無限の沈黙である私はお前に言葉を與へてやろう
			</span>
			<span
				class="marquee-content font-japanese text-beni px-12 font-bold not-italic"
				style="font-size: clamp(3rem, 6vw, 7.5rem);"
				aria-hidden="true"
			>
				無限の沈黙である私はお前に言葉を與へてやろう
			</span>
		</div>
	</div>

	<!-- Sections below marquee -->
	<div class="mx-auto mb-32 mt-16 flex w-full max-w-[1440px] flex-col gap-16 px-8">
		<!-- WRITING -->
		<PageSection label="Writing">
			<Text className="mbe-5 max-w-xl leading-[1.2]">
				Essays on design, code, philosophy, and the examined life. Published here since
				2007.
			</Text>
			<div class="flex flex-col gap-2">
				<MoreLink href="/writing/" text="Read the journal" />
				<MoreLink href="/rss.xml" text="Subscribe to RSS Feed" />
			</div>
		</PageSection>

		<!-- LATEST ESSAYS -->
		<PageSection label="Latest Essays">
			<DashList data-pagefind-ignore>
				{
					latestPosts.map((post) => (
						<DashListItem>
							<span class="text-beni select-none">— </span>
							<Link
								className="hover:opacity-60 transition-opacity text-3"
								href={`/${post.id}/`}
							>
								{post.data.subtitle
									? `${post.data.title}: ${post.data.subtitle}`
									: post.data.title}
							</Link>
						</DashListItem>
					))
				}
			</DashList>
		</PageSection>

		<!-- CONTACT -->
		<PageSection label="Contact">
			<MoreLink
				href="mailto:hey@stefanimhoff.de"
				text="hey@stefanimhoff.de"
				data-umami-event="Contact: Email"
			/>
		</PageSection>
	</div>
</BaseLayout>

<script>
	if (!CSS.supports('animation-timeline', 'view()')) {
		// Fallback: IntersectionObserver play/pause
		const band = document.querySelector('.marquee-band');
		if (band) {
			const observer = new IntersectionObserver(
				([entry]) => band.classList.toggle('is-visible', entry.isIntersecting),
				{ threshold: 0 }
			);
			observer.observe(band);
		}
	} else {
		// Set animation-range directly so scroll() timeline starts at the
		// equivalent of "entry 75%" and ends just before the page bottom.
		function setMarqueeRange() {
			const band = document.querySelector<HTMLElement>('.marquee-band');
			const track = document.querySelector<HTMLElement>('.marquee-track');
			if (!band || !track) return;
			const vh = window.innerHeight;
			const scrollMax = document.documentElement.scrollHeight - vh;
			if (scrollMax <= 0) return;
			const bandTop = band.getBoundingClientRect().top + window.scrollY;
			const bandH = band.offsetHeight;
			// entry 75% = 75% of band visible = scrolled to bandTop - vh + 0.25*bandH
			const startScroll = Math.max(0, bandTop - vh + bandH * 0.25);
			const startPct = ((startScroll / scrollMax) * 100).toFixed(2);
			track.style.setProperty('animation-range', `${startPct}% 96%`);
		}
		setMarqueeRange();
		window.addEventListener('resize', setMarqueeRange);
	}
</script>

<style>
	@keyframes marquee-scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	/* Fallback: time-based animation, play/pause via IntersectionObserver */
	.marquee-track {
		animation: marquee-scroll 25s linear infinite;
		animation-play-state: paused;
		will-change: transform;
	}

	.marquee-band.is-visible .marquee-track {
		animation-play-state: running;
	}

	/* Progressive enhancement: scroll-driven against root scroll */
	@supports (animation-timeline: scroll()) {
		.marquee-track {
			animation: marquee-scroll linear both;
			animation-timeline: scroll(root block);
			animation-play-state: running;
		}
	}
</style>
