---
import type { CollectionEntry } from 'astro:content';
type WritingType = CollectionEntry<'writing'>;
import { getCollection } from 'astro:content';

import { formatPosts, getWritingSlug } from '@/utils';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Marquee from '@/components/interactive/Marquee';
import Reveal from '@/components/interactive/motion/Reveal';
import HomePageSection from '@/components/ui/HomepagePageSection';
import JapanesePoem from '@/components/ui/JapanesePoem';
import EmailLink from '@/components/content/EmailLink';
import MoreLink from '@/components/ui/MoreLink';
import HeroTitle from '@/components/site/HeroTitle';
import LatestEssaysList from '@/components/site/LatestEssaysList';

import { Content as About } from '@/content/text/homepage/about.mdx';
import { Content as Work } from '@/content/text/homepage/work.mdx';
import { Content as Writing } from '@/content/text/homepage/writing.mdx';
import { mapping } from '@/mdx-components';
import { getPreviewUrl } from '@/utils/preview-url';

const allPosts = await getCollection('writing', ({ data }: WritingType) => !data.draft);
const latestPosts = formatPosts(allPosts, { limit: 9 });

const essayPosts = latestPosts.map((post) => ({
	href: `/writing/${getWritingSlug(post.id)}/`,
	previewUrl: getPreviewUrl(post.data.cover),
	label: post.data.subtitle ? `${post.data.title}: ${post.data.subtitle}` : post.data.title,
}));

const title = 'Stefan Imhoff';
const description = 'Design Engineer from Hamburg, Germany';
---

<BaseLayout title={title} description={description}>
	<!-- Hero -->
	<div
		class="max-w-360 pli-8 pbe-16 pbs-32 mx-auto grid grid-cols-3 gap-x-4 gap-y-6 md:grid-cols-6 md:gap-x-6 md:gap-y-8 xl:grid-cols-12 xl:gap-x-8 xl:gap-y-0"
	>
		<div class="col-span-3 flex w-full md:col-span-6 xl:col-span-9 xl:col-start-3">
			<HeroTitle client:load />
		</div>
	</div>

	<div class="max-w-360 mbe-16 pli-8 mx-auto flex w-full flex-col gap-16">
		<HomePageSection label="About">
			<About components={mapping} />
			<MoreLink href="/about/" text="About" data-umami-event="Home CTA: About" />
		</HomePageSection>

		<Reveal client:visible>
			<HomePageSection label="Work">
				<Work components={mapping} />
				<MoreLink
					href="/work/"
					text="See selected work"
					data-umami-event="Home CTA: Work"
				/>
			</HomePageSection>
		</Reveal>
	</div>

	<Marquee client:visible className="my-4">
		<JapanesePoem />
	</Marquee>

	<div class="max-w-360 mbe-32 mbs-16 pli-8 mx-auto flex w-full flex-col gap-16">
		<Reveal client:visible>
			<HomePageSection label="Writing">
				<Writing components={mapping} />
				<div class="flex flex-col gap-2">
					<MoreLink
						href="/writing/"
						text="Read the essays"
						data-umami-event="Home CTA: Writing"
					/>
					<MoreLink
						href="/rss.xml"
						text="Subscribe to RSS Feed"
						data-umami-event="Subscribe: RSS"
					/>
				</div>
			</HomePageSection>
		</Reveal>

		<HomePageSection label="Latest Essays" data-pagefind-ignore>
			<LatestEssaysList client:visible posts={essayPosts} />
		</HomePageSection>

		<HomePageSection label="Contact">
			<EmailLink
				data-name="hey"
				data-domain="stefanimhoff"
				data-tld="de"
				text="hey@stefanimhoff.de"
				data-umami-event="Contact: Email"
				client:idle
			/>
		</HomePageSection>
	</div>
</BaseLayout>
