---
import type { CollectionEntry } from 'astro:content';
type JournalType = CollectionEntry<'journal'>;
import { getCollection } from 'astro:content';

import { formatPosts } from '../utils';
import { site } from '../data/site';

import BaseLayout from '../layouts/BaseLayout.astro';
import PageSection from '../components/PageSection.astro';
import ArrowCta from '../components/icons/ArrowCta';

const allPosts = await getCollection('journal', ({ data }: JournalType) => !data.draft);
const latestPosts = formatPosts(allPosts, { limit: 9 });

const title = 'Stefan Imhoff';
const description = 'Design Engineer from Hamburg, Germany';
---

<BaseLayout title={title} description={description}>
	<!-- Hero -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pt-32 pb-32">
		<h1
			class="hero-title font-display text-[clamp(3.5rem,7.5vw,9rem)] font-bold leading-[1.05] tracking-tight text-sumi dark:text-washi"
		>
			Stefan Imhoff <em class="font-normal font-display">is a</em><br class="hidden lg:block" />
			Design Engineer<br class="hidden lg:block" />
			<span>
				<em class="font-normal font-display">from</em> Hamburg<span class="text-beni ml-4">—</span>
			</span>
		</h1>
	</div>

	<!-- Sections above marquee -->
	<div class="mx-auto w-full max-w-[1440px] px-8 flex flex-col gap-16 mb-16">
		<!-- ABOUT -->
		<PageSection label="About">
			<p class="mb-5 max-w-xl text-3 leading-[1.2]">
				Nearly two decades at the intersection of design and code. Guided by simplicity, structure,
				and the discipline of leaving things out.
			</p>
			<a class="cta-link text-3 font-bold hover:opacity-60 transition-opacity" href="/about/">
				About <ArrowCta aria-hidden="true" className="text-beni inline-block align-middle ml-2 h-[0.6em] w-auto" />
			</a>
		</PageSection>

		<!-- WORK -->
		<PageSection label="Work">
			<p class="mb-5 max-w-xl text-3 leading-[1.2]">
				I build interfaces that hold up under scrutiny — design systems, component libraries, and the
				invisible layer of decisions that makes a product coherent. For most of the last decade, that
				work was at XING, Europe's leading professional network.
			</p>
			<a class="cta-link text-3 font-bold hover:opacity-60 transition-opacity" href="/work/">
				See selected work <ArrowCta aria-hidden="true" className="text-beni inline-block align-middle ml-2 h-[0.6em] w-auto" />
			</a>
		</PageSection>
	</div>

	<!-- Haiku marquee band -->
	<div class="marquee-band overflow-hidden py-3 my-4" aria-hidden="true">
		<div class="marquee-track flex whitespace-nowrap">
			<span class="marquee-content font-japanese font-bold not-italic text-beni px-12"
				style="font-size: clamp(3rem, 6vw, 7.5rem);">
				無限の沈黙である私はお前に言葉を與へてやろう
			</span>
			<span class="marquee-content font-japanese font-bold not-italic text-beni px-12"
				style="font-size: clamp(3rem, 6vw, 7.5rem);" aria-hidden="true">
				無限の沈黙である私はお前に言葉を與へてやろう
			</span>
		</div>
	</div>

	<!-- Sections below marquee -->
	<div class="mx-auto w-full max-w-[1440px] px-8 flex flex-col gap-16 mt-16 mb-32">
		<!-- WRITING -->
		<PageSection label="Writing">
			<p class="mb-5 max-w-xl text-3 leading-[1.2]">
				Essays on design, code, philosophy, and the examined life. Published here since 2007.
			</p>
			<div class="flex flex-col gap-2">
				<a class="cta-link text-3 font-bold hover:opacity-60 transition-opacity" href="/writing/">
					Read the journal <ArrowCta aria-hidden="true" className="text-beni inline-block align-middle ml-2 h-[0.6em] w-auto" />
				</a>
				<a class="cta-link text-3 font-bold hover:opacity-60 transition-opacity" href="/rss.xml">
					Subscribe to RSS Feed <ArrowCta aria-hidden="true" className="text-beni inline-block align-middle ml-2 h-[0.6em] w-auto" />
				</a>
			</div>
		</PageSection>

		<!-- LATEST ESSAYS -->
		<PageSection label="Latest Essays">
			<ul class="flex flex-col gap-1" data-pagefind-ignore>
				{
					latestPosts.map((post) => (
						<li class="flex items-center gap-2 -ml-[calc(1em+0.5rem)]">
							<span class="text-beni select-none shrink-0">—</span>
							<a
								class="hover:opacity-60 transition-opacity text-3"
								href={`/${post.id}/`}
							>
								{post.data.title}
							</a>
						</li>
					))
				}
			</ul>
		</PageSection>

		<!-- CONTACT -->
		<PageSection label="Contact">
			<a
				class="cta-link text-3 font-bold hover:opacity-60 transition-opacity"
				href="mailto:hey@stefanimhoff.de"
				data-umami-event="Contact: Email"
			>
				hey@stefanimhoff.de <ArrowCta aria-hidden="true" className="text-beni inline-block align-middle ml-2 h-[0.6em] w-auto" />
			</a>
		</PageSection>
	</div>
</BaseLayout>

<script>
	if (!CSS.supports('animation-timeline', 'view()')) {
		// Fallback: IntersectionObserver play/pause
		const band = document.querySelector('.marquee-band');
		if (band) {
			const observer = new IntersectionObserver(
				([entry]) => band.classList.toggle('is-visible', entry.isIntersecting),
				{ threshold: 0 },
			);
			observer.observe(band);
		}
	} else {
		// Set animation-range directly so scroll() timeline starts at the
		// equivalent of "entry 75%" and ends just before the page bottom.
		function setMarqueeRange() {
			const band = document.querySelector('.marquee-band');
			const track = document.querySelector('.marquee-track');
			if (!band || !track) return;
			const vh = window.innerHeight;
			const scrollMax = document.documentElement.scrollHeight - vh;
			if (scrollMax <= 0) return;
			const bandTop = band.getBoundingClientRect().top + window.scrollY;
			const bandH = band.offsetHeight;
			// entry 75% = 75% of band visible = scrolled to bandTop - vh + 0.25*bandH
			const startScroll = Math.max(0, bandTop - vh + bandH * 0.25);
			const startPct = ((startScroll / scrollMax) * 100).toFixed(2);
			track.style.animationRange = `${startPct}% 96%`;
		}
		setMarqueeRange();
		window.addEventListener('resize', setMarqueeRange);
	}
</script>

<style>
	@keyframes marquee-scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	/* Fallback: time-based animation, play/pause via IntersectionObserver */
	.marquee-track {
		animation: marquee-scroll 25s linear infinite;
		animation-play-state: paused;
		will-change: transform;
	}

	.marquee-band.is-visible .marquee-track {
		animation-play-state: running;
	}

	/* Progressive enhancement: scroll-driven against root scroll */
	@supports (animation-timeline: scroll()) {
		.marquee-track {
			animation: marquee-scroll linear both;
			animation-timeline: scroll(root block);
			animation-play-state: running;
		}
	}
</style>
