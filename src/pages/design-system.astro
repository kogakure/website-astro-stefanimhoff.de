---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { mapping } from '../mdx-components';

import SectionLabel from '../components/ui/SectionLabel';
import DisplayHeadline from '../components/ui/DisplayHeadline';
import DividerUI from '../components/ui/Divider';
import Title from '../components/ui/Title';
import Headline from '../components/ui/Headline';
import Subheadline from '../components/ui/Subheadline';
import Subsubheadline from '../components/ui/Subsubheadline';
import Text from '../components/ui/Text';
import TextLink from '../components/ui/TextLink';
import PageSection from '../components/ui/PageSection';
import PageHeading from '../components/ui/PageHeading';
import MoreLink from '../components/ui/MoreLink';
import Flag from '../components/ui/Flag';
import UnorderedList from '../components/ui/UnorderedList';
import OrderedList from '../components/ui/OrderedList';
import ListItem from '../components/ui/ListItem';
import Tag from '../components/ui/Tag';
import Link from '../components/ui/Link';
import ColorSwatch from '../components/content/ColorSwatch';
import Blockquote from '../components/content/Blockquote';
import Pullquote from '../components/content/Pullquote';
import Banner from '../components/content/Banner';
import DisplayBox from '../components/content/DisplayBox';

const sections = await getCollection('design-system');
sections.sort((a, b) => a.data.order - b.data.order);

const uiComponents = [
	{
		name: 'Title',
		file: 'ui/Title.tsx',
		description: 'Primary page heading, rendered as h1 by default. Polymorphic via `as` prop.',
	},
	{
		name: 'Headline',
		file: 'ui/Headline.tsx',
		description: 'Section heading (h2). Polymorphic via `as` prop.',
	},
	{
		name: 'Subheadline',
		file: 'ui/Subheadline.tsx',
		description: 'Sub-section heading (h3). Polymorphic via `as` prop.',
	},
	{
		name: 'Subsubheadline',
		file: 'ui/Subsubheadline.tsx',
		description: 'Tertiary heading (h4). Polymorphic via `as` prop.',
	},
	{
		name: 'DisplayHeadline',
		file: 'ui/DisplayHeadline.tsx',
		description: 'Large display heading for hero sections.',
	},
	{
		name: 'Text',
		file: 'ui/Text.tsx',
		description: 'Paragraph text. Polymorphic via `as` prop.',
	},
	{
		name: 'TextLink',
		file: 'ui/TextLink.tsx',
		description: 'Inline text link with Beni color styling.',
	},
	{
		name: 'Link',
		file: 'ui/Link.tsx',
		description: 'Navigation link with animated arrow and hover effect.',
	},
	{
		name: 'MoreLink',
		file: 'ui/MoreLink.tsx',
		description: 'Call-to-action link with arrow icon.',
	},
	{
		name: 'SectionLabel',
		file: 'ui/SectionLabel.tsx',
		description: 'Uppercase tracking-widest label for section headers.',
	},
	{
		name: 'PageSection',
		file: 'ui/PageSection.tsx',
		description: 'Section wrapper with integrated SectionLabel.',
	},
	{
		name: 'PageHeading',
		file: 'ui/PageHeading.tsx',
		description: 'Page-level heading with SectionLabel prefix. Polymorphic via `as` prop.',
	},
	{ name: 'Tag', file: 'ui/Tag.tsx', description: 'Inline tag/chip with active state support.' },
	{ name: 'Flag', file: 'ui/Flag.tsx', description: 'Small label flag with optional link.' },
	{
		name: 'Divider',
		file: 'ui/Divider.tsx',
		description: 'Horizontal rule divider with subtle styling.',
	},
	{
		name: 'UnorderedList / ListItem',
		file: 'ui/UnorderedList.tsx',
		description: 'Standard unordered list with disc bullets.',
	},
	{
		name: 'OrderedList / ListItem',
		file: 'ui/OrderedList.tsx',
		description: 'Ordered list with decimal numbering.',
	},
];

const contentComponents = [
	{
		name: 'ColorSwatch',
		file: 'content/ColorSwatch.tsx',
		description: 'Interactive color swatch card with flip animation.',
	},
	{
		name: 'Blockquote',
		file: 'content/Blockquote.tsx',
		description: 'Styled blockquote with Beni left border.',
	},
	{
		name: 'Pullquote',
		file: 'content/Pullquote.tsx',
		description: 'Large decorative pull quote for emphasis.',
	},
	{ name: 'Banner', file: 'content/Banner.tsx', description: 'Full-width informational banner.' },
	{
		name: 'ThemeBox',
		file: 'content/ThemeBox.tsx',
		description:
			'Dual-theme box — renders light content in light mode and dark content in dark mode.',
	},
	{
		name: 'DisplayBox',
		file: 'content/DisplayBox.tsx',
		description: 'Display-level box for featured content.',
	},
];

const interactiveComponents = [
	{
		name: 'CommandMenu',
		file: 'interactive/CommandMenu.tsx',
		description: 'Keyboard-driven command palette (Cmd+K). Not rendered in preview.',
	},
	{
		name: 'BarChart',
		file: 'interactive/BarChart.tsx',
		description: 'Bar chart visualization using Recharts.',
	},
	{
		name: 'DoughnutChart',
		file: 'interactive/DoughnutChart.tsx',
		description: 'Doughnut chart visualization using Recharts.',
	},
	{
		name: 'WritingPage',
		file: 'interactive/WritingPage.tsx',
		description: 'Interactive writing/journal page component.',
	},
	{
		name: 'WritingList',
		file: 'interactive/WritingList.tsx',
		description: 'Interactive writing list with filtering.',
	},
];

const iconComponents = [
	'ArrowCta',
	'ArrowLeft',
	'ArrowLeftS',
	'ArrowRight',
	'ArrowRightS',
	'ArrowUp',
	'Close',
	'Copyright',
	'Download',
	'Github',
	'Hanko',
	'Instagram',
	'Mail',
	'MailSend',
	'Menu',
	'Moon',
	'Rss',
	'Search',
	'Sun',
	'Twitter',
	'TwitterX',
];
---

<BaseLayout title="Design System" description="The Ma (間) Design System — the space between.">
	<div class="mx-auto w-full max-w-[1440px] px-8 pt-32">
		<PageHeading>Design System</PageHeading>
		<Text className="text-hai mbs-6 mbe-0 max-w-xl leading-relaxed">
			The Ma (間) Design System — the space between. Two letters. Instantly memorable.
		</Text>
	</div>

	<div class="mx-auto w-full max-w-[1440px] px-8 pb-32">
		<nav class="border-shibui-300 dark:border-shibui-700 my-12 border-b pb-6">
			<SectionLabel as="p" className="mbe-3">Sections</SectionLabel>
			<ol class="columns-2 gap-x-8 sm:columns-3">
				{
					sections.map((section) => (
						<ListItem className="mbe-1">
							<TextLink className="text-3" href={`#section-${section.data.order}`}>
								{section.data.order} — {section.data.title}
							</TextLink>
						</ListItem>
					))
				}
				<ListItem className="mbe-1">
					<TextLink className="text-3" href="#components"> 10 — Components </TextLink>
				</ListItem>
			</ol>
		</nav>

		<div class="design-system-content max-w-[800px]">
			{
				sections.map(async (section) => {
					const { Content } = await render(section);
					return (
						<section id={`section-${section.data.order}`} class="mb-24">
							<div class="border-shibui-300 dark:border-shibui-700 mb-8 border-b pb-4">
								<span class="text-2 text-hai uppercase tracking-widest">
									{String(section.data.order).padStart(2, '0')}
								</span>
								<DisplayHeadline className="mbs-2">
									{section.data.title}
								</DisplayHeadline>
								{section.data.description && (
									<Text className="text-hai mbs-2 mbe-0">
										{section.data.description}
									</Text>
								)}
							</div>
							<Content components={mapping} />
						</section>
					);
				})
			}

			<section id="components" class="mb-24">
				<div class="border-shibui-300 dark:border-shibui-700 mb-8 border-b pb-4">
					<span class="text-2 text-hai uppercase tracking-widest">10</span>
					<DisplayHeadline className="mbs-2"> Components </DisplayHeadline>
					<Text className="text-hai mbs-2 mbe-0">
						UI primitives and content components used across the site.
					</Text>
				</div>

				<!-- UI Components -->
				<Subsubheadline
					as="h3"
					className="text-sumi dark:text-washi mbe-6 mbs-16 font-bold dark:font-bold"
					>UI Components</Subsubheadline
				>
				<Text className="text-hai mbe-8 max-w-xl leading-relaxed">
					Foundational building blocks for layout, typography, and navigation.
				</Text>

				{
					uiComponents.map((item) => (
						<div class="border-shibui-300 dark:border-shibui-700 rounded-2 mb-8 border p-6">
							<div class="mb-4 flex items-start justify-between gap-4">
								<div>
									<Subsubheadline className="text-sumi dark:text-washi font-bold dark:font-bold mbe-0">
										<code class="text-code bg-shibui-200 dark:bg-shibui-800 text-2 rounded px-1 font-mono">
											{`<${item.name}>`}
										</code>
									</Subsubheadline>
									<Text className="text-2 text-hai mbs-1 mbe-0">
										{item.description}
									</Text>
								</div>
								<span class="text-2 text-hai shrink-0 font-mono">{item.file}</span>
							</div>
							<div class="border-shibui-200 dark:border-shibui-700 rounded-2 dark:bg-shibui-900 border bg-white p-4">
								{item.name === 'Title' && <Title>Title Heading</Title>}
								{item.name === 'Headline' && <Headline>Headline</Headline>}
								{item.name === 'Subheadline' && (
									<Subheadline>Subheadline</Subheadline>
								)}
								{item.name === 'Subsubheadline' && (
									<Subsubheadline>Subsubheadline</Subsubheadline>
								)}
								{item.name === 'DisplayHeadline' && (
									<DisplayHeadline>DisplayHeadline</DisplayHeadline>
								)}
								{item.name === 'Text' && (
									<Text>Body text rendered with the Text component.</Text>
								)}
								{item.name === 'TextLink' && <TextLink href="#">TextLink</TextLink>}
								{item.name === 'Link' && <Link href="#">Link</Link>}
								{item.name === 'MoreLink' && (
									<MoreLink href="#" text="Learn More" />
								)}
								{item.name === 'SectionLabel' && (
									<SectionLabel>SECTION LABEL</SectionLabel>
								)}
								{item.name === 'PageSection' && (
									<PageSection label="About">Page section content.</PageSection>
								)}
								{item.name === 'PageHeading' && (
									<PageHeading>PageHeading</PageHeading>
								)}
								{item.name === 'Tag' && <Tag>Tag</Tag>}
								{item.name === 'Flag' && <Flag label="Flag" href="#" />}
								{item.name === 'Divider' && <DividerUI />}
								{item.name === 'UnorderedList / ListItem' && (
									<UnorderedList>
										<ListItem>Unordered item one</ListItem>
										<ListItem>Unordered item two</ListItem>
									</UnorderedList>
								)}
								{item.name === 'OrderedList / ListItem' && (
									<OrderedList>
										<ListItem>Ordered item one</ListItem>
										<ListItem>Ordered item two</ListItem>
									</OrderedList>
								)}
							</div>
						</div>
					))
				}

				<!-- Content Components -->
				<Subsubheadline
					as="h3"
					className="text-sumi dark:text-washi mbe-6 mbs-16 font-bold dark:font-bold"
				>
					Content Components
				</Subsubheadline>
				<Text className="text-hai mbe-8 max-w-xl leading-relaxed">
					Rich content elements for blog posts, pages, and featured sections.
				</Text>

				{
					contentComponents.map((item) => (
						<div class="border-shibui-300 dark:border-shibui-700 rounded-2 mb-8 border p-6">
							<div class="mb-4 flex items-start justify-between gap-4">
								<div>
									<Subsubheadline className="text-sumi dark:text-washi font-bold dark:font-bold mbe-0">
										<code class="text-code bg-shibui-200 dark:bg-shibui-800 text-2 rounded px-1 font-mono">
											{`<${item.name}>`}
										</code>
									</Subsubheadline>
									<Text className="text-2 text-hai mbs-1 mbe-0">
										{item.description}
									</Text>
								</div>
								<span class="text-2 text-hai shrink-0 font-mono">{item.file}</span>
							</div>
							<div class="border-shibui-200 dark:border-shibui-700 rounded-2 dark:bg-shibui-900 border bg-white p-4">
								{item.name === 'ColorSwatch' && (
									<ColorSwatch
										color="#900B20"
										title="Beni"
										description="Crimson, deep red — accent color"
									/>
								)}
								{item.name === 'Blockquote' && (
									<Blockquote>
										A meaningful quote from the design system.
									</Blockquote>
								)}
								{item.name === 'Pullquote' && (
									<Pullquote text="The space between is the design." />
								)}
								{item.name === 'Banner' && (
									<Banner>This is a banner message.</Banner>
								)}
								{item.name === 'ThemeBox' && (
									<div>
										<Text className="mbe-4 font-bold">Light mode:</Text>
										<div class="border-shibui-200 rounded-2 border bg-white p-4 dark:hidden">
											<Text className="mbe-0">
												Content visible in light mode
											</Text>
										</div>
										<Text className="mbe-4 font-bold">Dark mode:</Text>
										<div class="hidden dark:block">
											<Text className="mbe-0">
												Content visible in dark mode
											</Text>
										</div>
									</div>
								)}
								{item.name === 'DisplayBox' && (
									<DisplayBox>Display box content.</DisplayBox>
								)}
							</div>
						</div>
					))
				}

				<!-- Interactive Components -->
				<Subsubheadline
					as="h3"
					className="text-sumi dark:text-washi mbe-6 mbs-16 font-bold dark:font-bold"
				>
					Interactive Components
				</Subsubheadline>
				<Text className="text-hai mbe-8 max-w-xl leading-relaxed">
					Client-side interactive components requiring JavaScript state and user
					interaction.
				</Text>

				{
					interactiveComponents.map((item) => (
						<div class="border-shibui-300 dark:border-shibui-700 rounded-2 mb-8 border p-6">
							<div class="flex items-start justify-between gap-4">
								<div>
									<Subsubheadline className="text-sumi dark:text-washi font-bold dark:font-bold mbe-0">
										<code class="text-code bg-shibui-200 dark:bg-shibui-800 text-2 rounded px-1 font-mono">
											{`<${item.name}>`}
										</code>
									</Subsubheadline>
									<Text className="text-2 text-hai mbs-1 mbe-0">
										{item.description}
									</Text>
								</div>
								<span class="text-2 text-hai shrink-0 font-mono">{item.file}</span>
							</div>
						</div>
					))
				}

				<!-- Icon Components -->
				<Subsubheadline
					as="h3"
					className="text-sumi dark:text-washi mbe-6 mbs-16 font-bold dark:font-bold"
				>
					Icon Components
				</Subsubheadline>
				<Text className="text-hai mbe-8 max-w-xl leading-relaxed">
					SVG icon components from <code
						class="text-code bg-shibui-200 dark:bg-shibui-800 text-2 rounded px-1 font-mono"
						>icons/</code
					>.
				</Text>

				<div
					class="border-shibui-300 dark:border-shibui-700 rounded-2 grid grid-cols-3 gap-3 border p-6 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6"
				>
					{
						iconComponents.map((name) => (
							<div class="text-2 text-hai flex flex-col items-center gap-1">
								<code class="text-code bg-shibui-200 dark:bg-shibui-800 rounded px-1 font-mono text-[11px]">
									{name}
								</code>
							</div>
						))
					}
				</div>
			</section>
		</div>
	</div>
</BaseLayout>

<style is:global>
	@reference '../styles/global.css';

	.design-system-content {
		& h2 {
			@apply text-2 text-hai mb-4 mt-16 uppercase tracking-widest first:mt-0;
		}

		& h3 {
			@apply text-3 text-sumi dark:text-washi mb-2 mt-8 font-bold;
		}

		& p {
			@apply text-3 mb-5 max-w-xl leading-relaxed;
		}

		& ul,
		& ol {
			@apply text-3 mb-5 max-w-xl leading-relaxed;
		}

		& ul {
			@apply list-disc pl-5 md:pl-0;
		}

		& ol {
			@apply list-decimal pl-5 md:pl-0;
		}

		& li {
			@apply mb-1;
		}

		& a {
			@apply text-beni underline transition-opacity hover:opacity-60;
		}

		& strong {
			@apply font-bold;
		}

		& em {
			@apply italic;
		}

		& hr {
			@apply border-shibui-300 dark:border-shibui-700 my-12;
		}

		& blockquote {
			@apply border-beni text-hai border-l-2 pl-4 italic;
		}

		& pre {
			@apply rounded-2 text-code mb-8 overflow-auto p-4 font-mono;
		}

		& code:not(pre code) {
			@apply text-code bg-shibui-200 dark:bg-shibui-800 rounded px-1 font-mono;
		}

		& table {
			@apply text-2 text-hai mb-8 w-full border-collapse;
		}

		& th {
			@apply text-sumi dark:text-washi border-shibui-300 dark:border-shibui-700 border-b p-2 text-left font-bold;
		}

		& td {
			@apply border-shibui-200 dark:border-shibui-800 border-b p-2;
		}
	}
</style>
