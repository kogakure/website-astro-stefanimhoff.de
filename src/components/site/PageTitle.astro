---
import { cn } from '../../lib/utils';

import Title from '../ui/Title';

export interface Props {
	class?: string;
	titleClass?: string;
}

const { class: className, titleClass, ...props } = Astro.props;
---

<div
	class={cn(
		'grid grid-cols-3 gap-x-4 gap-y-6 md:grid-cols-6 md:gap-x-6 md:gap-y-8 xl:grid-cols-12 xl:gap-x-8 xl:gap-y-0 max-w-360 mx-auto w-full px-8 pb-16 pt-32',
		className
	)}
	{...props}
>
	<Title className={cn('col-span-3 md:col-span-6 xl:col-span-11 xl:col-start-2', titleClass)}
		><slot /></Title
	>
</div>
