---
export interface BreadcrumbItem {
	label: string;
	href?: string;
}

export interface Props {
	items: BreadcrumbItem[];
	label?: string;
	class?: string;
}

const { items, label = 'Breadcrumb', class: className } = Astro.props;
---

<nav
	aria-label={label}
	class:list={['max-w-360 pli-8 mx-auto w-full', className]}
	data-ma="Breadcrumb"
>
	<ol
		class="breadcrumb-list text-hai text-2 flex items-center font-sans uppercase tracking-wider"
	>
		{
			items.map((item, i) => {
				const isLast = i === items.length - 1;
				return (
					<li
						class={isLast ? 'text-nezumi' : ''}
						aria-current={isLast ? 'page' : undefined}
					>
						{item.href && !isLast ? (
							<a
								href={item.href}
								class="hover:text-sumi dark:hover:text-washi ease-enter duration-fast transition-colors"
							>
								{item.label}
							</a>
						) : (
							item.label
						)}
					</li>
				);
			})
		}
	</ol>

	<style>
		.breadcrumb-list li + li::before {
			content: '/';
			padding-inline: 0.5rem;
			color: var(--color-usuzumi);
			user-select: none;
		}
	</style>
</nav>
