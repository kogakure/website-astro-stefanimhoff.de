---
import { Rss } from '../icons';
import Link from '../ui/Link';
import Subsubheadline from '../ui/Subsubheadline';
---

<aside class="mbe-5 sm:mbe-0 grow" aria-label="Subscribe to RSS">
	<Subsubheadline as="h2">Stay up to date.</Subsubheadline>
	<p>
		<Rss aria-hidden="true" className="icon h-icon w-icon inline" />{' '}
		<Link
			className="hover:decoration-shibui-900/20 focus:decoration-shibui-900/20 dark:hover:decoration-shibui-100/20 dark:focus:decoration-shibui-100/20 font-light decoration-4 underline-offset-auto hover:underline focus:underline"
			data-umami-event="RSS"
			href="/rss.xml"
			target="_blank"
		>
			Subscribe via RSS
		</Link>
	</p>
</aside>
