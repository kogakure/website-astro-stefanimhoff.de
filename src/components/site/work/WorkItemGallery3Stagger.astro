---
import type { CollectionEntry } from 'astro:content';

import WorkContent from './WorkContent.astro';
import WorkImageOptimized from './WorkImageOptimized.astro';

interface Props {
	entry: CollectionEntry<'work'>;
	index: number;
}

const { entry } = Astro.props;
const images = entry.data.images ?? [];
---

<article
	class="grid grid-cols-3 gap-x-4 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8"
	data-ma="WorkItemGallery3Stagger"
>
	<WorkContent entry={entry} />
	{
		images[0] && (
			<WorkImageOptimized
				src={images[0].src}
				alt={images[0].alt ?? entry.data.title}
				sizes="(min-width: 1280px) 900px, (min-width: 768px) 66vw, 100vw"
				className="col-span-3 md:col-span-4 md:col-start-1 md:row-start-2 xl:col-span-8 xl:col-start-1 xl:row-start-2"
			/>
		)
	}
	{
		images[1] && (
			<WorkImageOptimized
				src={images[1].src}
				alt={images[1].alt ?? entry.data.title}
				sizes="(min-width: 1280px) 440px, (min-width: 768px) 33vw, 100vw"
				className="mbs-6 md:mbs-32 xl:mbs-32 col-span-3 md:col-span-2 md:col-start-5 md:row-span-2 md:row-start-2 xl:col-span-4 xl:col-start-9 xl:row-span-2 xl:row-start-2"
			/>
		)
	}
	{
		images[2] && (
			<WorkImageOptimized
				src={images[2].src}
				alt={images[2].alt ?? entry.data.title}
				sizes="(min-width: 1280px) 560px, (min-width: 768px) 50vw, 100vw"
				className="mbs-6 md:mbs-8 xl:mbs-8 col-span-3 md:col-span-3 md:col-start-2 md:row-start-3 xl:col-span-5 xl:col-start-4 xl:row-start-3"
			/>
		)
	}
</article>
