---
import type { CollectionEntry } from 'astro:content';

import WorkContent from './WorkContent.astro';
import WorkImage from './WorkImage';

interface Props {
	entry: CollectionEntry<'work'>;
	index: number;
}

const { entry } = Astro.props;
const images = entry.data.images ?? [];
---

<article class="grid grid-cols-3 gap-x-4 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8">
	<WorkContent entry={entry} />
	{
		images[0] && (
			<WorkImage
				src={images[0].src}
				alt={images[0].alt ?? entry.data.title}
				className="col-span-3 md:col-span-4 xl:col-span-8"
				client:visible
			/>
		)
	}
	{
		images[1] && (
			<WorkImage
				src={images[1].src}
				alt={images[1].alt ?? entry.data.title}
				className="mbs-6 md:mbs-32 xl:mbs-32 col-span-3 md:col-span-2 xl:col-span-4"
				client:visible
			/>
		)
	}
</article>
