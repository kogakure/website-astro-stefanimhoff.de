---
import type { CollectionEntry } from 'astro:content';

import WorkContent from './WorkContent.astro';
import WorkImageOptimized from './WorkImageOptimized.astro';

interface Props {
	entry: CollectionEntry<'work'>;
	index: number;
}

const { entry } = Astro.props;
const images = entry.data.images ?? [];
const offsets = ['', 'md:mbs-32 xl:mbs-32', 'md:mbs-16 xl:mbs-16'];
---

<article class="grid grid-cols-3 gap-x-4 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8">
	<WorkContent entry={entry} />
	{
		images.map((img, i) => (
			<WorkImageOptimized
				src={img.src}
				alt={img.alt ?? entry.data.title}
				sizes="(min-width: 1280px) 440px, (min-width: 768px) 33vw, 100vw"
				className={[
					'col-span-3 md:col-span-2 xl:col-span-4',
					i > 0 && 'mbs-6 md:mbs-0',
					offsets[i],
				]
					.filter(Boolean)
					.join(' ')}
			/>
		))
	}
</article>
