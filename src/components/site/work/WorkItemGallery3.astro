---
import type { CollectionEntry } from 'astro:content';

import WorkContent from './WorkContent.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const images = entry.data.images ?? [];
const offsets = ['', 'md:mbs-32 xl:mbs-32', 'md:mbs-16 xl:mbs-16'];
---

<article class="grid grid-cols-3 gap-x-4 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8">
	<WorkContent entry={entry} />
	{
		images.map((img, i) => (
			<div
				class:list={[
					'rounded-2 col-span-3 overflow-hidden md:col-span-2 xl:col-span-4',
					i > 0 && 'mbs-6 md:mbs-0',
					offsets[i],
				]}
			>
				<img
					src={img.src}
					alt={img.alt ?? entry.data.title}
					data-lightbox="true"
					tabindex="0"
					role="button"
					aria-label="Open image in lightbox"
					class="ease-enter w-full cursor-zoom-in transition-[transform,filter] duration-200 hover:scale-[1.01] hover:brightness-[1.03]"
					loading="lazy"
					decoding="async"
				/>
			</div>
		))
	}
</article>
