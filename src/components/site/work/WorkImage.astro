---
interface Props {
	src: string;
	alt: string;
	className?: string;
}

const { src, alt, className } = Astro.props;
---

<div class:list={['rounded-2 overflow-hidden', className]}>
	<button
		type="button"
		aria-label="Open image in lightbox"
		class="block h-full w-full cursor-zoom-in border-0 bg-transparent p-0"
		data-lightbox="true"
	>
		<img
			src={src}
			alt={alt}
			class="ease-enter h-full w-full object-cover transition-[transform,filter] duration-200 hover:scale-[1.01] hover:brightness-[1.03]"
			loading="lazy"
			decoding="async"
		/>
	</button>
</div>
