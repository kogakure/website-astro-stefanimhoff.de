---
interface Props {
	src: string;
	alt: string;
	className?: string;
}

const { src, alt, className } = Astro.props;
---

<div class:list={['rounded-2 overflow-hidden', className]}>
	<img
		src={src}
		alt={alt}
		data-lightbox="true"
		tabindex="0"
		role="button"
		aria-label="Open image in lightbox"
		class="ease-enter h-full w-full cursor-zoom-in object-cover transition-[transform,filter] duration-200 hover:scale-[1.01] hover:brightness-[1.03]"
		loading="lazy"
		decoding="async"
	/>
</div>
