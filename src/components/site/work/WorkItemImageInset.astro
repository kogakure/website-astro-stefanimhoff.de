---
import type { CollectionEntry } from 'astro:content';

import WorkContent from './WorkContent.astro';
import WorkImage from './WorkImage';

interface Props {
	entry: CollectionEntry<'work'>;
	index: number;
}

const { entry } = Astro.props;
const image = entry.data.image;
---

<article class="grid grid-cols-3 gap-x-4 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8">
	<WorkContent entry={entry} />
	{
		image && (
			<WorkImage
				src={image.src}
				alt={entry.data.title}
				className="col-span-3 md:col-span-6 xl:col-span-10 xl:col-start-2"
				client:visible
			/>
		)
	}
</article>
