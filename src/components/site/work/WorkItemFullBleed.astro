---
import type { CollectionEntry } from 'astro:content';

import WorkContent from './WorkContent.astro';

interface Props {
	entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const image = entry.data.image;
---

<article class="grid grid-cols-3 gap-x-4 md:grid-cols-6 md:gap-x-6 xl:grid-cols-12 xl:gap-x-8">
	<WorkContent entry={entry} />
	{
		image && (
			<div class="rounded-2 col-span-3 overflow-hidden md:col-span-6 xl:col-span-12">
				<img
					src={image.src}
					alt={entry.data.title}
					data-lightbox="true"
					tabindex="0"
					role="button"
					aria-label="Open image in lightbox"
					class="ease-enter w-full cursor-zoom-in transition-[transform,filter] duration-200 hover:scale-[1.01] hover:brightness-[1.03]"
					loading="lazy"
					decoding="async"
				/>
			</div>
		)
	}
</article>
