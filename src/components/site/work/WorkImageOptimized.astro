---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';
import WorkImage from './WorkImage';

interface Props {
	src: ImageMetadata;
	alt: string;
	sizes: string;
	className?: string;
}

const { src, alt, sizes, className } = Astro.props;

const optimized = await getImage({
	src,
	widths: [400, 800, 1200, 1600, 2400],
	formats: ['avif', 'webp'],
});

const largeSrc = optimized.srcSet.values.at(-1)?.url ?? optimized.src;
---

<WorkImage
	src={optimized.src}
	srcset={optimized.srcSet.attribute}
	sizes={sizes}
	width={src.width}
	height={src.height}
	alt={alt}
	largeSrc={largeSrc}
	className={className}
	client:visible
/>
