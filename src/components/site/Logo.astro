---
import { Hanko } from '../icons';
import Link from '../ui/Link';
---

<Link
	aria-label="To Homepage"
	className="group inline-flex cursor-pointer border-0 text-[0]"
	href="/"
>
	<Hanko
		aria-hidden="true"
		className="icon fill-beni ease-standard h-[clamp(40px,3vw,55px)] w-[clamp(40px,3vw,55px)] transition-transform duration-300 group-hover:rotate-3 group-focus:rotate-3 group-active:rotate-0"
	/>
</Link>
