---
import { Hanko } from '../icons';
import Link from '../ui/Link';
---

<Link
	aria-label="To Homepage"
	className="group inline-flex cursor-pointer border-0 text-[0]"
	href="/"
>
	<Hanko
		aria-hidden="true"
		className="icon fill-beni h-[clamp(40px,_3vw,_55px)] w-[clamp(40px,_3vw,_55px)] transition-transform duration-300 [transition-timing-function:var(--ease-standard)] group-hover:rotate-3 group-focus:rotate-3 group-active:rotate-0"
	/>
</Link>
