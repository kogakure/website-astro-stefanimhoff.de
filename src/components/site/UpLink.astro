---
import { ArrowUp } from '../icons';
import Link from '../ui/Link';

export interface Props {
	[key: string]: any;
}

const { ...props } = Astro.props;
---

<div class="flex flex-1 justify-end" {...props}>
	<Link
		aria-label="Back to top"
		className="transition-transform duration-500 ease-in-out hover:-translate-y-1 focus:-translate-y-1"
		data-umami-event="Back to top"
		href="#top"
		id="up-link"
	>
		<button
			aria-hidden="true"
			class="h-clickarea w-clickarea flex cursor-pointer items-center justify-center"
		>
			<ArrowUp aria-hidden="true" className="icon h-icon w-icon" />
		</button>
	</Link>
</div>
