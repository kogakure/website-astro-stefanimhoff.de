---
interface Props {
	src: string;
	alt: string;
	class?: string;
	style?: string;
}

const { src, alt, class: className, style } = Astro.props;
---

<img
	src={src}
	alt={alt}
	loading="eager"
	fetchpriority="high"
	decoding="async"
	class:list={['rounded-2 w-full object-cover', className]}
	style={style}
	data-ma="CoverImage"
/>
