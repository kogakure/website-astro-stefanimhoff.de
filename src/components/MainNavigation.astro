---
import navigation from '../data/navigation.json';

const currentPath = Astro.url.pathname;
const isActive = (url: string) =>
	url === '/' ? currentPath === '/' : currentPath.startsWith(url);
---

<nav class="hidden items-center md:flex" role="navigation" aria-label="Main">
	<ul class="nav-list flex items-center">
		{
			navigation.map(({ title, url }) => (
				<li class="nav-item">
					<a
						class:list={[
							'px-1 text-sm transition-opacity hover:opacity-60',
							isActive(url) && 'underline decoration-beni underline-offset-4',
						]}
						data-umami-event={`Nav: ${title}`}
						href={url}
					>
						{title}
					</a>
				</li>
			))
		}
	</ul>
</nav>

<style>
	.nav-item + .nav-item::before {
		content: '·';
		padding: 0 0.4rem;
		color: var(--color-hai);
		user-select: none;
	}
</style>
