---
interface Props {
	label: string;
	class?: string;
}

const { label, class: className } = Astro.props;
---

<section class:list={['grid gap-6 md:grid-cols-[160px_1fr] md:gap-16', className]}>
	<div>
		<span class="block text-2 tracking-widest uppercase text-hai">{label}</span>
	</div>
	<div class="min-w-0 flex-1">
		<slot />
	</div>
</section>
