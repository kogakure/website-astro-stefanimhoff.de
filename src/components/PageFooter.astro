---
import { GithubLogo, InstagramLogo, XLogo } from '@phosphor-icons/react';
import Link from '../components/Link.astro';
---

<footer class="flex justify-center py-16 print:hidden" aria-label="Site footer">
	<Link
		aria-label="Twitter/X"
		class="flex h-clickarea w-clickarea cursor-pointer items-center justify-center transition-opacity duration-300 ease-in-out hover:opacity-60 focus:opacity-60"
		data-umami-event="Social Icon: 𝕏"
		href="https://x.com/kogakure"
		title="𝕏"
	>
		<XLogo aria-hidden="true" className="icon h-icon-small w-icon-small" />
	</Link>
	<Link
		aria-label="Instagram"
		class="flex h-clickarea w-clickarea cursor-pointer items-center justify-center transition-opacity duration-300 ease-in-out hover:opacity-60 focus:opacity-60"
		data-umami-event="Social Icon: Instagram"
		href="https://instagram.com/kogakure"
		title="Instagram"
	>
		<InstagramLogo aria-hidden="true" className="icon h-icon-small w-icon-small" />
	</Link>
	<Link
		aria-label="GitHub"
		class="flex h-clickarea w-clickarea cursor-pointer items-center justify-center transition-opacity duration-300 ease-in-out hover:opacity-60 focus:opacity-60"
		data-umami-event="Social Icon: GitHub"
		href="https://github.com/kogakure"
		title="GitHub"
	>
		<GithubLogo aria-hidden="true" className="icon h-icon-small w-icon-small" />
	</Link>
</footer>
