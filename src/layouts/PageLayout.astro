---
import { dateToFormat, dateToISO } from '../utils';

import Pullquote from '../components/content/Pullquote';
import Image from '../components/content/Image';
import PageTitle from '../components/site/PageTitle.astro';

import GridLayout from './GridLayout.astro';

export interface Props {
	class?: string;
	frontmatter?: any;
	grid?: 'wide' | 'narrow';
}

const { frontmatter, class: className, grid = 'narrow' } = Astro.props;
const gridVariant = frontmatter.grid || grid;
---

<GridLayout grid={gridVariant} class={className} {...frontmatter}>
	<PageTitle slot="title">
		{frontmatter.title}
	</PageTitle>
	{
		frontmatter.cover && (
			<div
				slot="before-content"
				class="!mbe-0 md:col-end-17 xl:col-end-14 3xl:col-end-13 [&_img]:!mbe-0 md:[&_img]:rounded-2 col-span-full aspect-video h-auto md:col-start-3 print:hidden [&_img]:!w-full [&_img]:!max-w-none [&_img]:rounded-none [&_picture]:!w-full [&_picture]:!max-w-none"
			>
				<Image
					alt={frontmatter.title}
					src={frontmatter.cover}
					fullWidth
					fullHeight
					className="!mbe-0"
				/>
			</div>
		)
	}
	{
		frontmatter.intro && (
			<div class="multicol-span" slot="intro">
				<Pullquote alignment="left" text={frontmatter.intro} />
			</div>
		)
	}
	<slot name="before-content" />
	<slot />
	{
		frontmatter.updated && (
			<footer class="multicol-span mbs-10">
				<b>Last Updated:</b>
				<time datetime={dateToISO(frontmatter.updated)}>
					{dateToFormat(frontmatter.updated)}
				</time>
			</footer>
		)
	}
	<slot name="after-content" />
</GridLayout>
