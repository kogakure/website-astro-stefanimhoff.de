---
import BaseLayout from './BaseLayout.astro';
import PageTitle from '../components/site/PageTitle.astro';

export interface Props {
	frontmatter?: any;
	title?: string;
	description?: string;
	cover?: string;
}

const { frontmatter, title: titleProp, description: descProp, cover: coverProp } = Astro.props;

const title = frontmatter?.title ?? titleProp ?? '';
const description = frontmatter?.description ?? descProp ?? '';
const cover = frontmatter?.cover ?? coverProp;
---

<BaseLayout title={title} description={description} cover={cover}>
	<!-- Page title -->
	<PageTitle>{title}</PageTitle>

	{
		cover && (
			<div class="max-w-360 mx-auto w-full px-8 pb-16">
				<img
					src={cover}
					alt={title}
					class="rounded-2 w-full object-cover"
					loading="eager"
					decoding="async"
				/>
			</div>
		)
	}

	<!-- Content -->
	<div class="max-w-360 mx-auto w-full px-8 pb-32">
		<div
			class="simple-content grid grid-cols-3 gap-x-4 gap-y-6 md:grid-cols-6 md:gap-x-6 md:gap-y-8 xl:grid-cols-12 xl:gap-x-8 xl:gap-y-0"
		>
			<slot />
		</div>
	</div>
</BaseLayout>

<style is:global>
	@reference "../styles/global.css";

	.simple-content > * {
		@apply col-span-3 md:col-span-5 xl:col-span-6 xl:col-start-4;
	}

	.simple-content > h2 {
		@apply text-2 text-hai col-span-3 self-start uppercase md:col-span-2 md:col-start-1 xl:col-span-2 xl:col-start-2;
		@apply mb-0 mt-10 font-normal tracking-normal dark:font-normal;
	}

	.simple-content > h2:first-child {
		@apply mt-0;
	}

	.simple-content > h2 + * {
		@apply xl:mt-10;
	}

	.simple-content > h2:first-child + * {
		@apply xl:mt-0;
	}

	.simple-content > h3 {
		@apply text-3 text-sumi dark:text-washi mb-2 mt-8 font-bold;
	}

	.simple-content strong {
		@apply font-bold;
	}

	.simple-content em {
		@apply italic;
	}

	.simple-content pre {
		@apply rounded-2 text-code mb-8 overflow-auto p-4 font-mono;
	}
</style>
