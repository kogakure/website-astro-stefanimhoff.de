---
import BaseLayout from './BaseLayout.astro';
import PageHeading from '../components/ui/PageHeading';

export interface Props {
	frontmatter?: any;
	title?: string;
	description?: string;
	cover?: string;
}

const { frontmatter, title: titleProp, description: descProp, cover: coverProp } = Astro.props;

const title = frontmatter?.title ?? titleProp ?? '';
const description = frontmatter?.description ?? descProp ?? '';
const cover = frontmatter?.cover ?? coverProp;
---

<BaseLayout title={title} description={description} cover={cover}>
	<!-- Page title -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-16 pt-32">
		<PageHeading>{title}</PageHeading>
	</div>

	{
		cover && (
			<div class="mx-auto w-full max-w-[1440px] px-8 pb-16">
				<img
					src={cover}
					alt={title}
					class="rounded-2 w-full object-cover"
					loading="eager"
					decoding="async"
				/>
			</div>
		)
	}

	<!-- Content -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-32">
		<div class="simple-content">
			<slot />
		</div>
	</div>
</BaseLayout>

<style is:global>
	@reference "../styles/global.css";

	.simple-content {
		display: grid;
		grid-template-columns: 1fr;
		row-gap: 0;
	}

	@media (min-width: 768px) {
		.simple-content {
			grid-template-columns: 160px 1fr;
			column-gap: 4rem;
		}

		.simple-content > * {
			grid-column: 2;
		}

		.simple-content > h2 {
			grid-column: 1;
		}
	}

	.simple-content > h2 {
		@apply text-2 text-hai self-start uppercase tracking-widest;
		@apply mt-10 md:mt-0 md:pt-[0.35em];
	}

	.simple-content > h2:first-child {
		@apply mt-0;
	}

	.simple-content > h3 {
		@apply text-3 text-sumi dark:text-washi mb-2 mt-8 font-bold;
	}

	.simple-content > p,
	.simple-content p {
		@apply text-3 mb-5 max-w-xl leading-relaxed;
	}

	.simple-content > ul,
	.simple-content > ol {
		@apply text-3 mb-5 max-w-xl leading-relaxed;
	}

	.simple-content > ul {
		@apply list-disc pl-5 md:pl-0;
	}

	.simple-content > ol {
		@apply list-decimal pl-5 md:pl-0;
	}

	.simple-content li {
		@apply mb-1;
	}

	.simple-content a {
		@apply text-beni underline transition-opacity hover:opacity-60;
	}

	.simple-content strong {
		@apply font-bold;
	}

	.simple-content em {
		@apply italic;
	}

	.simple-content > hr {
		@apply border-shibui-300 dark:border-shibui-700 my-12;
	}

	.simple-content blockquote {
		@apply border-beni text-hai border-l-2 pl-4 italic;
	}

	.simple-content pre {
		@apply rounded-2 text-code mb-8 overflow-auto p-4 font-mono;
	}

	.simple-content code:not(pre code) {
		@apply text-code bg-shibui-200 dark:bg-shibui-800 rounded px-1 font-mono;
	}
</style>
