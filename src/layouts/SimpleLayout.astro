---
import BaseLayout from './BaseLayout.astro';

export interface Props {
	frontmatter?: any;
	title?: string;
	description?: string;
	cover?: string;
}

const { frontmatter, title: titleProp, description: descProp, cover: coverProp } = Astro.props;

const title = frontmatter?.title ?? titleProp ?? '';
const description = frontmatter?.description ?? descProp ?? '';
const cover = frontmatter?.cover ?? coverProp;
---

<BaseLayout title={title} description={description} cover={cover}>
	<!-- Page title -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-16 pt-32">
		<h1
			class="font-display text-sumi dark:text-washi text-[clamp(3.5rem,7.5vw,9rem)] font-bold leading-[0.92] tracking-tight"
		>
			{title}
		</h1>
	</div>

	{
		cover && (
			<div class="mx-auto w-full max-w-[1440px] px-8 pb-16">
				<img
					src={cover}
					alt={title}
					class="rounded-2 w-full object-cover"
					loading="eager"
					decoding="async"
				/>
			</div>
		)
	}

	<!-- Content -->
	<div class="mx-auto w-full max-w-[1440px] px-8 pb-32">
		<div class="simple-content max-w-[800px]">
			<slot />
		</div>
	</div>
</BaseLayout>

<style is:global>
	@reference "../styles/global.css";

	.simple-content {
		& h2 {
			@apply text-2 text-hai mb-4 mt-16 uppercase tracking-widest first:mt-0;
		}

		& h3 {
			@apply text-3 text-sumi dark:text-washi mb-2 mt-8 font-bold;
		}

		& p {
			@apply text-3 mb-5 max-w-xl leading-relaxed;
		}

		& ul,
		& ol {
			@apply text-3 mb-5 max-w-xl leading-relaxed;
		}

		& ul {
			@apply list-disc pl-5 md:pl-0;
		}

		& ol {
			@apply list-decimal pl-5 md:pl-0;
		}

		& li {
			@apply mb-1;
		}

		& a {
			@apply text-beni underline transition-opacity hover:opacity-60;
		}

		& strong {
			@apply font-bold;
		}

		& em {
			@apply italic;
		}

		& hr {
			@apply border-shibui-300 dark:border-shibui-700 my-12;
		}

		& blockquote {
			@apply border-beni text-hai border-l-2 pl-4 italic;
		}

		& pre {
			@apply rounded-2 text-code mb-8 overflow-auto p-4 font-mono;
		}

		& code:not(pre code) {
			@apply text-code bg-shibui-200 dark:bg-shibui-800 rounded px-1 font-mono;
		}
	}
</style>
