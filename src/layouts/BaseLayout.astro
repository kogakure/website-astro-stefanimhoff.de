---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SEO } from 'astro-seo';
import { site } from '../data/site';
import { isProduction } from '../utils';

import ThemeProvider from '../components/site/ThemeProvider.astro';
import PageHeader from '../components/site/PageHeader.astro';
import PageFooter from '../components/site/PageFooter.astro';
import CommandMenu from '../components/interactive/CommandMenu';
import HoverPreview from '../components/interactive/HoverPreview';
import Scripts from '../components/site/Scripts.astro';

export interface Props {
	cover?: string;
	description?: string;
	footer?: boolean;
	header?: boolean;
	nofollow?: boolean;
	noindex?: boolean;
	ogType?: 'article' | 'website';
	title: string;
}

const {
	description,
	footer = true,
	header = true,
	nofollow,
	noindex,
	ogType = 'website',
	title,
	cover = '/assets/images/og/ma.jpg',
} = Astro.props;

const isExternalCover = /^https?:\/\//.test(cover);

const ogImage =
	!isExternalCover && cover.startsWith('/assets/images/cover/') && cover.endsWith('.webp')
		? cover.replace('/assets/images/cover/', '/assets/images/og/').replace(/\.webp$/, '.jpg')
		: cover;

const currentPath = Astro.url.pathname;
const fullTitle = `${title} · ${site.description}`;
const fullDescription = description || site.description;
const fullUrl = site.url + currentPath;
const fullImage = isExternalCover ? ogImage : site.url + ogImage;

const schema = JSON.stringify({
	'@context': 'https://schema.org/',
	'@type': 'WebSite',
	name: site.author,
	url: site.url,
});

const pagefind = !noindex && { 'data-pagefind-body': '' };
const extraLinks = isProduction ? [{ rel: 'manifest', href: '/manifest.webmanifest' }] : [];
---

<!doctype html>
<html lang="en" class="no-js box-border scroll-smooth">
	<head>
		<SEO
			charset="UTF-8"
			title={fullTitle}
			description={fullDescription}
			canonical={fullUrl}
			nofollow={nofollow}
			noindex={noindex}
			openGraph={{
				basic: {
					image: fullImage,
					title: fullTitle,
					type: ogType,
					url: fullUrl,
				},
				image: {
					height: 675,
					width: 1200,
				},
				optional: {
					description: fullDescription,
				},
			}}
			twitter={{
				card: 'summary_large_image',
				creator: site.x,
				description: fullDescription,
				image: fullImage,
				site: site.x,
				title: fullTitle,
			}}
			extend={{
				link: [
					{ rel: 'preconnect', href: 'https://umami.kogakure.cloud' },
					{ rel: 'stylesheet', href: '/assets/styles/print.css', media: 'print' },
					{ rel: 'sitemap', href: '/sitemap-index.xml' },
					{ rel: 'icon', href: '/favicon.ico' },
					{
						rel: 'icon',
						href: '/assets/images/favicons/favicon.svg',
						type: 'image/svg+xml',
					},
					{
						rel: 'apple-touch-icon',
						href: '/assets/images/favicons/apple-touch-icon.png',
					},
					...extraLinks,
					{
						as: 'font',
						crossorigin: '',
						href: '/assets/fonts/boska-variable.woff2',
						rel: 'preload',
						type: 'font/woff2',
					},
					{
						as: 'font',
						crossorigin: '',
						href: '/assets/fonts/switzer-variable.woff2',
						rel: 'preload',
						type: 'font/woff2',
					},
					{
						rel: 'alternate',
						type: 'application/rss+xml',
						title: 'Stefan Imhoff',
						href: site.url + '/rss.xml',
					},
					{
						rel: 'alternate',
						type: 'application/rss+xml',
						title: 'Stefan Imhoff (Haiku)',
						href: site.url + '/rss-haiku.xml',
					},
				],
				meta: [
					{
						name: 'viewport',
						content: 'width=device-width, initial-scale=1.0, viewport-fit=cover',
					},
					{ name: 'author', content: site.author },
					{ name: 'generator', content: Astro.generator },
				],
			}}
		/>

		<script is:inline>
			document.documentElement.classList.remove('no-js');
			document.documentElement.classList.add('js');
		</script>
		<ClientRouter />
		<ThemeProvider />
		{
			isProduction && (
				<script
					is:inline
					defer
					src="https://umami.kogakure.cloud/script.js"
					data-website-id="ca67348d-b662-4205-a2c1-f1d8e4c68adb"
				/>
			)
		}
		<Scripts />
		<Fragment
			set:html={`<style>@supports selector(::search-text){::search-text{background-color:var(--color-usuzumi);color:var(--color-sumi)}::search-text:current{background-color:var(--color-hai);color:var(--color-sumi)}.dark ::search-text{background-color:var(--color-nezumi);color:var(--color-washi)}.dark ::search-text:current{background-color:var(--color-usuzumi);color:var(--color-sumi)}}</style>`}
		/>
	</head>
	<body
		class="bg-washi text-sumi common-ligatures dark:bg-yoru dark:text-washi flex min-h-screen flex-col font-sans font-normal leading-relaxed"
	>
		<a
			href="#main-content"
			class="rounded-b-2 bg-beni pbl-3 pli-6 text-2 text-washi ease-enter z-200 fixed left-1/2 top-0 -translate-x-1/2 -translate-y-full font-semibold uppercase tracking-wider transition-transform duration-200 focus:translate-y-0"
			>Skip to main content</a
		>
		<div class="flex grow flex-col">
			{header && <PageHeader />}
			<div class="page-content flex grow">
				<main id="main-content" class="w-full" {...pagefind}>
					<slot />
				</main>
			</div>
			{footer && <PageFooter />}
		</div>
		<CommandMenu client:idle />
		<HoverPreview client:idle transition:persist />
		<script>
			console.info(
				'👋 I see you’re interested in the source code of this site? You can find it here 👉 https://github.com/kogakure/website-astro-stefanimhoff.de'
			);
		</script>
		<script is:inline type="application/ld+json" set:html={schema} />
		<style is:global>
			@reference "../styles/global.css";
			.astro-code {
				@apply rounded-2 text-code mbe-10 mbs-0 overflow-auto p-4 font-mono;
			}
		</style>
		<slot name="rss-writer" />
	</body>
</html>
