{
	"name": "astro-stefanimhoff.de",
	"type": "module",
	"version": "2.0.0",
	"scripts": {
		"astro": "astro",
		"build": "astro build",
		"design:lint": "design.md lint DESIGN.md",
		"dev": "astro dev",
		"docker:build": "podman build --platform linux/amd64 -t stefanimhoff-local .",
		"docker:build:test": "podman build --platform linux/amd64 --target builder -t stefanimhoff-test .",
		"docker:run": "podman run -p 8080:80 stefanimhoff-local",
		"docker:test": "pnpm docker:build:test",
		"og:generate": "node og-generate.cjs",
		"previews:generate": "node preview-generate.cjs",
		"images": "npm-run-all og:generate previews:generate",
		"plop": "plop",
		"preflight": "pnpm test && pnpm docker:test",
		"prepreview": "pnpm run build",
		"preview": "astro preview --open",
		"start": "astro dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage && open coverage/index.html",
		"webp": "node convert-images.cjs"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.8",
		"@astrojs/mdx": "^5.0.3",
		"@astrojs/react": "^5.0.3",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@phosphor-icons/react": "^2.1.10",
		"@tailwindcss/vite": "^4.2.2",
		"astro": "^6.1.5",
		"astro-pagefind": "^1.8.6",
		"astro-seo": "^1.1.0",
		"astro-webmanifest": "^1.0.0",
		"astrojs-service-worker": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"deepmerge": "^4.3.1",
		"github-slugger": "^2.0.0",
		"mdast-util-to-string": "^4.0.0",
		"moment": "^2.30.1",
		"motion": "^12.38.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"reading-time": "^1.5.0",
		"recharts": "^3.8.1",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"unist-util-visit": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.9.0",
		"@google/design.md": "^0.1.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/mdast": "^4.0.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/unist": "^3.0.2",
		"@typescript-eslint/parser": "^8.0.0",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"eslint": "^9.3.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-astro": "^1.2.0",
		"eslint-plugin-jsx-a11y": "^6.8.0",
		"eslint-plugin-prettier": "^5.1.3",
		"glob": "^11.0.0",
		"globals": "^17.5.0",
		"happy-dom": "^20.5.0",
		"husky": "^9.0.11",
		"jimp": "^0.22.12",
		"jsdom": "^28.0.0",
		"lint-staged": "^15.2.4",
		"lodash": "^4.17.21",
		"markdown-it": "^14.1.0",
		"npm-run-all": "^4.1.5",
		"pagefind": "^1.1.0",
		"plop": "^4.0.1",
		"prettier": "^3.2.5",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-astro-organize-imports": "^0.4.8",
		"prettier-plugin-organize-imports": "^4.0.0",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"remark-gfm": "^4.0.1",
		"rollup": "^4.18.0",
		"sanitize-html": "^2.14.0",
		"sharp": "^0.33.4",
		"svgo": "^3.3.2",
		"typescript": "^5.4.5",
		"vite": "^6.0.0",
		"vitest": "^4.0.18"
	},
	"pnpm": {
		"supportedArchitectures": {
			"libc": [
				"musl"
			]
		},
		"overrides": {
			"sharp": "0.33.4",
			"rollup": "npm:@rollup/wasm-node"
		},
		"ignoredBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	}
}
